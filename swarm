#!/usr/bin/env python3
"""Minimal state-backed candidate Swarm CLI for v0 live conformance."""

from __future__ import annotations

import os
import sqlite3
import sys
import uuid
from copy import deepcopy
from datetime import datetime
from pathlib import Path
from typing import Any, Callable


SCHEMA_VERSION = 5
STATE_FILE = "state.sqlite3"


def message(
    seq: int,
    target: str,
    msg_id: str,
    timestamp: str,
    sender_type: str,
    author: str,
    body: str,
) -> dict[str, Any]:
    return {
        "seq": seq,
        "target": target,
        "id": msg_id,
        "time": timestamp,
        "type": sender_type,
        "author": author,
        "body": body,
    }


def inbox_item(
    target: str,
    msg_id: str,
    timestamp: str,
    sender_type: str,
    author: str,
    body: str,
) -> dict[str, Any]:
    return {
        "target": target,
        "message_id": msg_id,
        "time": timestamp,
        "type": sender_type,
        "author": author,
        "body": body,
    }


