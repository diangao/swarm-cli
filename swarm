            FROM integration_services
            ORDER BY name
            """
        ).fetchall()
    ]
    integration_logins = [
        integration_login_item(
            row["service"],
            row["status"],
            row["account"],
            row["local_home"],
            row["created_at"],
            row["updated_at"],
        )
        for row in conn.execute(
            """
            SELECT service, status, account, local_home, created_at, updated_at
            FROM integration_logins
            ORDER BY service
            """
        ).fetchall()
    ]
    channels = [
        channel_item(
            row["name"],
            bool(row["private"]),
            bool(row["joined"]),
            row["description"],
        )
        for row in conn.execute(
            "SELECT name, private, joined, description FROM channels ORDER BY name"
        ).fetchall()
    ]
    channel_members = [
        channel_member_item(
            row["channel"],
            row["name"],
            row["kind"],
            row["role"],
            row["status"],
        )
        for row in conn.execute(
            "SELECT channel, name, kind, role, status FROM channel_members ORDER BY channel, kind, name"
        ).fetchall()
    ]
    profiles = [
        profile_item(
            row["name"],
            row["display_name"],
            row["kind"],
            row["description"],
            row["avatar_url"],
            row["avatar_file"],
        )
        for row in conn.execute(
            """
            SELECT name, display_name, kind, description, avatar_url, avatar_file
            FROM profiles
            ORDER BY kind, name
            """
        ).fetchall()
    ]
    thread_attention = [
        thread_attention_item(row["target"], bool(row["followed"]), row["updated_at"])
        for row in conn.execute(
            "SELECT target, followed, updated_at FROM thread_attention ORDER BY target"
        ).fetchall()
    ]
    return {
        "schema_version": SCHEMA_VERSION,
        "next_seq": meta_int(conn, "next_seq", 1),
        "next_id_counter": meta_int(conn, "next_id_counter", 0),
        "next_task_number": meta_int(conn, "next_task_number", 1),
        "last_read": last_read,
        "messages": messages,
        "slack_workspaces": slack_workspaces,
        "slack_messages": slack_messages,
        "agents": agents,
        "agent_heartbeats": agent_heartbeats,
        "remote_inbox": inbox_rows(conn, "remote"),
        "local_inbox": inbox_rows(conn, "local"),
        "freshness": freshness,
        "tasks": tasks,
        "reminders": reminders,
        "reminder_events": reminder_events,
        "attachments": attachments,
        "message_attachments": message_attachments,
        "message_reactions": message_reactions,
        "action_cards": action_cards,
        "integration_services": integration_services,
        "integration_logins": integration_logins,
        "channels": channels,
        "channel_members": channel_members,
        "profiles": profiles,
        "thread_attention": thread_attention,
    }


def load_state() -> dict[str, Any]:
    conn = connect_state()
    try:
        initialize_database(conn)
        return read_state(conn)
    finally:
        conn.close()


def save_state(state: dict[str, Any]) -> None:
    conn = connect_state()
    try:
        initialize_database(conn)
        with conn:
            replace_state(conn, state)
    finally:
        conn.close()


def with_read_state(action: Callable[[dict[str, Any]], int]) -> int:
    state = load_state()
    return action(state)


def with_mutable_state(action: Callable[[dict[str, Any]], int]) -> int:
    conn = connect_state()
    try:
        initialize_database(conn)
        conn.execute("BEGIN IMMEDIATE")
        state = read_state(conn)
        result = action(state)
        replace_state(conn, state)
        conn.commit()
        return result
    except Exception:
        conn.rollback()
        raise
    finally:
        conn.close()


def short_id(msg_id: str) -> str:
    return msg_id.split("-", 1)[0]


def format_attachment_summary(record: dict[str, Any]) -> str:
    attachments = record.get("attachments") or []
    if not attachments:
        return ""
    label = "attachment" if len(attachments) == 1 else "attachments"
    items = ", ".join(
        f"{attachment['filename']} (id:{attachment['id']}, {attachment['mime_type']}, "
        f"{attachment['size_bytes']} bytes)"
        for attachment in attachments
    )
    return f" [{len(attachments)} {label}: {items}]"


def format_reaction_summary(record: dict[str, Any]) -> str:
    reactions = record.get("reactions") or []
    if not reactions:
        return ""
    grouped: dict[str, list[str]] = {}
    for reaction in reactions:
        grouped.setdefault(str(reaction["emoji"]), []).append(str(reaction["author"]))
    items = []
    for emoji in sorted(grouped):
        authors = sorted(set(grouped[emoji]))
        items.append(f"{emoji} x{len(authors)} @{', @'.join(authors)}")
    return f" [reactions: {', '.join(items)}]"


def format_history_row(record: dict[str, Any]) -> str:
    return (
        f"[seq={record['seq']} msg={record['id']} time={record['time']} "
        f"type={record['type']}] @{record['author']}: {record['body']}"
        f"{format_attachment_summary(record)}"
        f"{format_reaction_summary(record)}"
    )


def format_canonical_message(record: dict[str, Any]) -> str:
    return (
        f"[target={record['target']} msg={short_id(str(record['id']))} time={record['time']} "
        f"type={record['type']}] @{record['author']}: {record['body']}"
        f"{format_attachment_summary(record)}"
        f"{format_reaction_summary(record)}"
    )


def format_inbox_row(record: dict[str, Any]) -> str:
    msg = record.get("msg") or short_id(str(record["message_id"]))
    return (
        f"[target={record['target']} msg={msg} time={record['time']} "
        f"type={record['type']}] @{record['author']}: {record['body']}"
    )


def format_task_row(record: dict[str, Any]) -> str:
    assignee = f" \u2192 @{record['assignee']}" if record.get("assignee") else ""
    return (
        f"#{record['number']} [{record['status']}] {record['title']}{assignee} "
        f"(by @{record['creator']}) msg={short_id(str(record['message_id']))}"
    )


def format_reminder_row(record: dict[str, Any]) -> str:
    target = f" target={record['target']}" if record.get("target") else ""
    recurrence = f" every={record['recurrence']}" if record.get("recurrence") else ""
    return (
        f"{record['id']} [{record['status']}] {record['title']}{target} "
        f"next={record['next_fire_at']}{recurrence}"
    )


def format_channel_row(record: dict[str, Any]) -> str:
    visibility = "private" if record.get("private") else "public"
    joined = "joined" if record.get("joined") else "not joined"
    description = f" - {record['description']}" if record.get("description") else ""
    return f"- {record['name']} ({visibility}, {joined}){description}"


def format_integration_row(service: dict[str, Any], login: dict[str, Any] | None) -> str:
    if login is None:
        status = "no local record"
        suffix = ""
    else:
        status = f"local record present, account={login['account']}"
        suffix = f" local_home={login['local_home']}"
    env_label = "local env" if service.get("requires_local_env") else "no local env"
    return (
        f"- {service['name']} ({service['kind']}, {status}, {env_label})"
        f" - {service['description']}{suffix}"
