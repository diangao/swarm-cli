        encoding="utf-8",
    )
    runner = runtime_dir / "curator_cycle.py"
    runner.write_text(runner_source, encoding="utf-8")
    runner.chmod(0o755)
    (destination / "MEMORY.md").write_text(
        f"# {agent['display_name']}\n\n"
        "## Role\n"
        "Curate the owner's research dashboard through the swarm daemon resident runtime.\n\n"
        "## Contract\n"
        "- Run only bounded curator cycles; no infinite loop or self heartbeat.\n"
