def read_slack_event_payload(argv: list[str]) -> tuple[dict[str, Any] | None, str | None]:
    if flag_missing_value(argv, "--event-file"):
        return None, "--event-file requires a value"
    event_file = arg_value(argv, "--event-file")
    if event_file is not None:
        path = Path(event_file).expanduser()
        try:
            raw = path.read_text()
        except OSError:
            return None, f"Slack event file not found: {event_file}"
    else:
        raw = sys.stdin.read()
    if not raw.strip():
        return None, "Slack event JSON is required on stdin or --event-file"
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError:
        return None, "invalid Slack event JSON"
    if not isinstance(payload, dict):
        return None, "Slack event JSON must be an object"
    return payload, None


def command_slack_configure(argv: list[str]) -> int:
    if (
        flag_missing_value(argv, "--workspace")
        or flag_missing_value(argv, "--bot-token-env")
        or flag_missing_value(argv, "--signing-secret-env")
        or flag_missing_value(argv, "--app-token-env")
        or flag_missing_value(argv, "--mode")
    ):
        return write_stderr("Error: Slack config flags require values\nCode: INVALID_ARG\n")
    workspace = arg_value(argv, "--workspace")
    bot_token_env = arg_value(argv, "--bot-token-env")
    signing_secret_env = arg_value(argv, "--signing-secret-env")
    app_token_env = arg_value(argv, "--app-token-env")
    mode = arg_value(argv, "--mode") or "events_api"
    if not workspace or not workspace.strip():
        return write_stderr("Error: --workspace is required\nCode: INVALID_ARG\n")
    if not bot_token_env or not valid_env_var_name(bot_token_env):
        return write_stderr("Error: --bot-token-env must be a valid environment variable name\nCode: INVALID_ARG\n")
    if signing_secret_env is not None and not valid_env_var_name(signing_secret_env):
        return write_stderr("Error: --signing-secret-env must be a valid environment variable name\nCode: INVALID_ARG\n")
    if app_token_env is not None and not valid_env_var_name(app_token_env):
        return write_stderr("Error: --app-token-env must be a valid environment variable name\nCode: INVALID_ARG\n")
    if mode not in {"events_api", "socket_mode"}:
        return write_stderr("Error: --mode must be events_api or socket_mode\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        now = current_timestamp()
        existing = slack_workspace_by_id(state, workspace.strip())
        if existing is None:
            state.setdefault("slack_workspaces", []).append(
                slack_workspace_item(
                    workspace.strip(),
                    bot_token_env,
                    signing_secret_env,
                    app_token_env,
                    mode,
                    now,
                    now,
                )
            )
        else:
            existing["bot_token_env"] = bot_token_env
            existing["signing_secret_env"] = signing_secret_env
            existing["app_token_env"] = app_token_env
            existing["mode"] = mode
            existing["updated_at"] = now
