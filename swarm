def command_reminder_schedule(argv: list[str]) -> int:
    title = reminder_title_from_args(argv)
    if title is None or not title.strip():
        return write_stderr("Error: reminder title is required\nCode: INVALID_ARG\n")
    next_fire_at = schedule_time_from_args(argv)
    if next_fire_at is None:
        return write_stderr("Error: --at or --in with s/m/h/d duration is required\nCode: INVALID_ARG\n")
    target = arg_value(argv, "--target")
    if target is not None and not (target.startswith("#") or target.startswith("dm:@")):
        return write_stderr("Error: reminder target must be a channel, thread, or DM\nCode: INVALID_TARGET\n")
    recurrence = arg_value(argv, "--every")

    def action(state: dict[str, Any]) -> int:
        now = current_timestamp()
        reminder_id = next_reminder_id(state)
        reminder = reminder_item(
            reminder_id,
            title.strip(),
            target,
            "scheduled",
            next_fire_at,
            recurrence,
            now,
            now,
        )
        state.setdefault("reminders", []).append(reminder)
        detail = f"title={reminder['title']} next={next_fire_at}"
        if target:
            detail += f" target={target}"
        if recurrence:
            detail += f" every={recurrence}"
        append_reminder_event(state, reminder_id, "scheduled", detail)
        return write_stdout(
            f"Reminder {reminder_id} scheduled for {next_fire_at}."
            f"{' Target: ' + target + '.' if target else ''}\n"
        )

    return with_mutable_state(action)


def command_reminder_snooze(argv: list[str]) -> int:
    reminder_id = reminder_id_from_args(argv)
    if reminder_id is None:
        return write_stderr("Error: --id is required\nCode: INVALID_ARG\n")
    next_fire_at = schedule_time_from_args(argv, absolute_flag="--until", relative_flag="--for")
    if next_fire_at is None:
        return write_stderr("Error: --until or --for with s/m/h/d duration is required\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        reminder = reminder_by_id(state, reminder_id)
        if reminder is None:
            return write_stderr("Error: Reminder not found\nCode: NOT_FOUND\n")
        if reminder["status"] == "canceled":
            return write_stderr("Error: canceled reminders cannot be snoozed\nCode: UPDATE_FAILED\n")
        old_next = reminder["next_fire_at"]
        reminder["next_fire_at"] = next_fire_at
        reminder["status"] = "snoozed"
        reminder["updated_at"] = current_timestamp()
        append_reminder_event(state, reminder_id, "snoozed", f"{old_next} -> {next_fire_at}")
        return write_stdout(f"Reminder {reminder_id} snoozed: {old_next} -> {next_fire_at}.\n")

    return with_mutable_state(action)


def command_reminder_update(argv: list[str]) -> int:
    reminder_id = reminder_id_from_args(argv)
    if reminder_id is None:
        return write_stderr("Error: --id is required\nCode: INVALID_ARG\n")
    title = arg_value(argv, "--title")
    target = arg_value(argv, "--target")
    next_fire_at = schedule_time_from_args(argv)
    recurrence = arg_value(argv, "--every")
    if title is None and target is None and next_fire_at is None and recurrence is None:
        return write_stderr("Error: provide --title, --target, --at/--in, or --every\nCode: INVALID_ARG\n")
    if target is not None and target != "none" and not (target.startswith("#") or target.startswith("dm:@")):
        return write_stderr("Error: reminder target must be a channel, thread, DM, or none\nCode: INVALID_TARGET\n")

    def action(state: dict[str, Any]) -> int:
        reminder = reminder_by_id(state, reminder_id)
        if reminder is None:
            return write_stderr("Error: Reminder not found\nCode: NOT_FOUND\n")
        if reminder["status"] == "canceled":
            return write_stderr("Error: canceled reminders cannot be updated\nCode: UPDATE_FAILED\n")
        changes: list[str] = []
        if title is not None:
            changes.append(f"title={reminder['title']} -> {title.strip()}")
            reminder["title"] = title.strip()
        if target is not None:
            next_target = None if target == "none" else target
            changes.append(f"target={reminder.get('target')} -> {next_target}")
            reminder["target"] = next_target
        if next_fire_at is not None:
            changes.append(f"next={reminder['next_fire_at']} -> {next_fire_at}")
            reminder["next_fire_at"] = next_fire_at
            if reminder["status"] == "snoozed":
                reminder["status"] = "scheduled"
        if recurrence is not None:
            next_recurrence = None if recurrence == "none" else recurrence
            changes.append(f"every={reminder.get('recurrence')} -> {next_recurrence}")
            reminder["recurrence"] = next_recurrence
        reminder["updated_at"] = current_timestamp()
        append_reminder_event(state, reminder_id, "updated", "; ".join(changes))
        return write_stdout(f"Reminder {reminder_id} updated.\n")

    return with_mutable_state(action)


def command_reminder_cancel(argv: list[str]) -> int:
