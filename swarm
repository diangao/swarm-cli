def command_integration_login(argv: list[str]) -> int:
    service_name = service_from_args(argv)
    if service_name is None:
        return write_stderr("Error: --service is required\nCode: INVALID_ARG\n")
    if not valid_service_name(service_name):
        return write_stderr("Error: invalid service name\nCode: INVALID_ARG\n")
    account = arg_value(argv, "--account") or "local-placeholder"
    if not account.strip():
        return write_stderr("Error: --account must be non-empty\nCode: INVALID_ARG\n")
    account = account.strip()

    def action(state: dict[str, Any]) -> int:
        service = integration_service_by_name(state, service_name)
        if service is None:
            return write_stderr(f"Error: Unknown integration service: {service_name}\nCode: NOT_FOUND\n")
        existing = integration_login_by_service(state, service_name)
        if existing is not None:
            if existing["account"] != account and account != "local-placeholder":
                return write_stderr(
                    f"Error: Local integration record already exists for {service_name} "
                    f"with account {existing['account']}\n"
                    "Code: UPDATE_FAILED\n"
                )
            return write_stdout(
                f"Local integration record already exists for {service_name}.\n"
                "Remote authentication was not performed.\n"
                f"Status: {existing['status']}\n"
            )

        env_paths = ensure_integration_profile_dirs(service_name)
        now = current_timestamp()
        state.setdefault("integration_logins", []).append(
            integration_login_item(
                service_name,
                "local_placeholder",
                account,
                env_paths["HOME"],
                now,
                now,
            )
        )
        return write_stdout(
            f"Local integration record created for {service_name}.\n"
            "Remote authentication was not performed.\n"
            "Status: local_placeholder\n"
            f"Local home: {env_paths['HOME']}\n"
        )

    return with_mutable_state(action)


def command_integration_env(argv: list[str]) -> int:
    service_name = service_from_args(argv)
    if service_name is None:
        return write_stderr("Error: --service is required\nCode: INVALID_ARG\n")
    if not valid_service_name(service_name):
        return write_stderr("Error: invalid service name\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        service = integration_service_by_name(state, service_name)
        if service is None:
            return write_stderr(f"Error: Unknown integration service: {service_name}\nCode: NOT_FOUND\n")
        login = integration_login_by_service(state, service_name)
        if login is None:
            return write_stderr(
                f"Error: Local integration record not found for {service_name}\n"
                "Code: NOT_FOUND\n"
                f"Next action: create one with swarm integration login --service {service_name}\n"
            )
        if not service.get("requires_local_env"):
            return write_stdout(
                f"No local environment is required for {service_name}.\n"
                f"Status: {login['status']}\n"
            )
        root = Path(login["local_home"]).parent
        env = {
            "SWARM_INTEGRATION_SERVICE": service_name,
            "SWARM_INTEGRATION_STATUS": login["status"],
            "SWARM_INTEGRATION_ACCOUNT": login["account"],
            "HOME": str(root / "home"),
            "XDG_CONFIG_HOME": str(root / "config"),
            "XDG_DATA_HOME": str(root / "data"),
            "XDG_CACHE_HOME": str(root / "cache"),
        }
        lines = [
            "# Local integration environment only; no remote credentials are provisioned.",
            *[f"export {key}={shlex.quote(value)}" for key, value in env.items()],
        ]
        return write_stdout("\n".join(lines) + "\n")

    return with_read_state(action)


