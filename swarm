def parse_state_timestamp(value: str | None) -> datetime | None:
    if not value:
        return None
    try:
        return datetime.strptime(value, "%Y-%m-%d %H:%M:%S")
    except ValueError:
        return None


def dispatch_lease_available(item: dict[str, Any], now: datetime) -> bool:
    if item["status"] == "pending":
        return True
    if item["status"] != "leased":
        return False
    expires = parse_state_timestamp(item.get("lease_expires_at"))
    return expires is not None and expires <= now


def command_daemon_dispatch_enqueue(argv: list[str]) -> int:
    unknown = unknown_flags(argv, {"--agent", "--kind", "--payload", "--max-attempts"})
    if unknown:
        return write_stderr(f"Error: unknown daemon dispatch enqueue flag: {unknown[0]}\nCode: INVALID_ARG\n")
    if (
        flag_missing_value(argv, "--agent")
        or flag_missing_value(argv, "--kind")
        or flag_missing_value(argv, "--payload")
        or flag_missing_value(argv, "--max-attempts")
    ):
        return write_stderr("Error: daemon dispatch enqueue flags require values\nCode: INVALID_ARG\n")
    agent = arg_value(argv, "--agent")
    kind = arg_value(argv, "--kind") or "manual"
    payload = arg_value(argv, "--payload")
    max_attempts_text = arg_value(argv, "--max-attempts")
    if not agent or not agent.strip():
        return write_stderr("Error: --agent is required\nCode: INVALID_ARG\n")
    if payload is None:
        return write_stderr("Error: --payload is required\nCode: INVALID_ARG\n")
    max_attempts = 3
    if max_attempts_text is not None:
        try:
            max_attempts = int(max_attempts_text)
        except ValueError:
            max_attempts = 0
        if max_attempts <= 0:
            return write_stderr("Error: --max-attempts must be a positive integer\nCode: INVALID_ARG\n")
    agent_name = agent.strip()

    def action(state: dict[str, Any]) -> int:
        if not any(record["name"] == agent_name for record in state.get("agents", [])):
            return write_stderr(f"Error: Agent not found: {agent_name}\nCode: NOT_FOUND\n")
        dispatches = state.setdefault("daemon_dispatches", [])
        next_id = max((item["id"] for item in dispatches), default=0) + 1
        dispatches.append(
            daemon_dispatch_item(
                next_id,
                current_timestamp(),
                agent_name,
                kind.strip(),
                payload,
                "pending",
                0,
                max_attempts,
                None,
                None,
                None,
                None,
            )
        )
        append_daemon_event(state, "dispatch_enqueued", {"id": next_id, "agent": agent_name, "kind": kind.strip()})
        return write_stdout(
            f"Dispatch {next_id} enqueued for @{agent_name}.\n"
            f"Kind: {kind.strip()}\n"
            f"Max attempts: {max_attempts}\n"
        )

    return with_mutable_state(action)



def command_daemon_dispatch_claim(argv: list[str]) -> int:
