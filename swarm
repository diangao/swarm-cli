def message(
    seq: int,
    target: str,
    msg_id: str,
    timestamp: str,
    sender_type: str,
    author: str,
    body: str,
) -> dict[str, Any]:
    return {
        "seq": seq,
        "target": target,
        "id": msg_id,
        "time": timestamp,
        "type": sender_type,
        "author": author,
        "body": body,
    }


