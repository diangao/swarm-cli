def slack_thread_ts_for_target(
    state: dict[str, Any],
    workspace: str,
    target: str,
) -> tuple[str | None, str | None]:
    if ":" not in target:
        return None, None
    parent = parent_message_for_thread(state, target)
    if parent is None:
        return None, "thread root message not found"
    root_mapping = slack_mapping_by_message_id(state, workspace, str(parent["id"]))
    if root_mapping is None:
        return None, "thread root is not mapped to Slack"
    return str(root_mapping["slack_ts"]), None


def slack_record_needs_outbound(
