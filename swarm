def safe_watch_id(value: str) -> str:
    normalized = []
    for char in value.lower():
        if char.isalnum():
            normalized.append(char)
        elif char in {"-", "_", ".", "/", ":"}:
            normalized.append("-")
    result = "".join(normalized).strip("-")
    return result or uuid.uuid4().hex[:8]


def source_text_is_owner_sensitive(value: str) -> bool:
    lowered = value.lower()
    markers = (
        "fde tracker",
        "company tracker",
        "interview tracker",
        "candidate tracker",
        "notion tracker",
        "personal tracker",
    )
    return any(marker in lowered for marker in markers)


def flatten_json_items(value: Any) -> list[Any]:
    if isinstance(value, list):
        return value
    if isinstance(value, dict):
        for key in ("items", "entities", "watchlist", "sources"):
            nested = value.get(key)
            if isinstance(nested, list):
                return nested
        return list(value.values())
    return []


def curator_entry_from_raw(kind: str, item: Any) -> dict[str, str] | None:
    if isinstance(item, str):
        name = item.strip()
        if not name:
            return None
        return {
            "id": f"{kind}:{safe_watch_id(name)}",
            "kind": kind,
            "name": name,
            "why_watched": "owner-selected watch item",
            "trust_tier": "owner-selected",
            "scan_surface": "manual watch list",
            "cadence": "hourly curator cycle",
            "retirement_condition": "retire when repeated cycles produce no actionable signal",
        }
    if not isinstance(item, dict):
        return None
    raw_id = str(item.get("id") or item.get("entityId") or item.get("slug") or item.get("name") or item.get("title") or "").strip()
    name = str(item.get("name") or item.get("title") or raw_id).strip()
    if not raw_id and not name:
        return None
    surface = str(item.get("scan_surface") or item.get("surface") or item.get("url") or item.get("kind") or "manual watch list").strip()
    why = str(item.get("why_watched") or item.get("why") or item.get("description") or "configured watch item").strip()
    trust = str(item.get("trust_tier") or item.get("trust") or "configured-source").strip()
    cadence = str(item.get("cadence") or "hourly curator cycle").strip()
    retirement = str(item.get("retirement_condition") or item.get("retire_when") or "retire when repeated cycles produce no actionable signal").strip()
    return {
        "id": f"{kind}:{safe_watch_id(raw_id or name)}",
        "kind": kind,
        "name": name or raw_id,
        "why_watched": why,
        "trust_tier": trust,
        "scan_surface": surface,
        "cadence": cadence,
        "retirement_condition": retirement,
    }


def load_curator_watch_entries(
    source_config: str | None,
    entity_radar: str | None,
    owner_watchlist: str | None,
) -> tuple[list[dict[str, str]], dict[str, int], str | None]:
    entries: list[dict[str, str]] = []
    counters = {
        "source_entries": 0,
        "entity_entries": 0,
        "owner_entries": 0,
        "excluded_owner_sensitive": 0,
        "excluded_dm_originals": 0,
    }

    def add_entries(path_text: str | None, kind: str) -> str | None:
        if not path_text:
            return None
        path = Path(path_text).expanduser()
        try:
            data = json.loads(path.read_text(encoding="utf-8"))
        except OSError as exc:
            return f"cannot read {kind} file: {type(exc).__name__}"
        except json.JSONDecodeError as exc:
            return f"invalid JSON in {kind} file: {exc.msg}"
        for raw in flatten_json_items(data):
            entry = curator_entry_from_raw(kind, raw)
            if entry is None:
                continue
            combined = json.dumps(entry, sort_keys=True)
            if contains_credential_shape(combined):
                return f"credential-shaped value found in {kind} seed input"
            surface = entry["scan_surface"].strip().lower()
            if surface.startswith("dm:") or "direct message" in surface:
                counters["excluded_dm_originals"] += 1
                continue
            if source_text_is_owner_sensitive(combined):
                counters["excluded_owner_sensitive"] += 1
                continue
            entries.append(entry)
            if kind == "source":
                counters["source_entries"] += 1
            elif kind == "entity":
                counters["entity_entries"] += 1
            else:
                counters["owner_entries"] += 1
        return None

    for path_text, kind in ((source_config, "source"), (entity_radar, "entity"), (owner_watchlist, "owner")):
        error = add_entries(path_text, kind)
        if error is not None:
            return [], counters, error

    unique: dict[str, dict[str, str]] = {}
    for entry in entries:
        unique.setdefault(entry["id"], entry)
    ordered = [unique[key] for key in sorted(unique)]
    if not ordered:
        return [], counters, "curator watch list would be empty"
    return ordered, counters, None


def curator_runtime_source() -> str:
    return r'''#!/usr/bin/env python3
import argparse
import json
import os
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path


def load_json(path, fallback):
    if not path.exists():
        return fallback
    with path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def dump_json(path, value):
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as handle:
        json.dump(value, handle, indent=2, sort_keys=True)
        handle.write("\n")


def clean_excerpt(job):
    return str(job.get("excerpt") or "").strip()


def make_annotation(job):
    title = str(job.get("title") or "Untitled").strip() or "Untitled"
    excerpt = clean_excerpt(job)
    summary_seed = excerpt.split(".")[0].strip() or excerpt
    words = summary_seed.split()
    summary = " ".join(words[:20]) if words else title
    if len(summary) < 12:
        summary = f"{title}: {summary}"
    tags = job.get("tags")
    if not isinstance(tags, list) or not tags:
        tags = ["agents"]
    tags = [str(tag).strip().lower().replace(" ", "-") for tag in tags if str(tag).strip()][:3] or ["agents"]
    return {
        "id": job.get("id"),
        "summary": summary[:280],
        "whyItMatters": None,
        "tags": tags,
        "priority": str(job.get("priority") or "medium") if str(job.get("priority") or "medium") in {"high", "medium", "low"} else "medium",
    }


def send_report(target, author, body):
    if not target:
        return
    completed = subprocess.run(
        ["swarm", "message", "send", "--target", target, "--author", author],
        input=body,
        text=True,
        capture_output=True,
        timeout=20,
    )
    if completed.returncode == 0 and "Freshness hold:" in completed.stdout:
        completed = subprocess.run(
            ["swarm", "message", "send", "--send-draft", "--target", target, "--author", author],
            text=True,
            capture_output=True,
            timeout=20,
        )
    if completed.returncode != 0:
        sys.stderr.write(completed.stderr or completed.stdout)
        raise SystemExit(1)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--resume", default="")
    args = parser.parse_args()
    del args
    workspace = Path.cwd()
    config = load_json(workspace / "runtime" / "curator-config.json", {})
    batch_size = int(config.get("batch_size", 10))
    max_runtime_seconds = float(config.get("max_runtime_seconds", 300))
    report_target = str(config.get("report_target") or "")
    agent = os.environ.get("SWARM_AGENT_NAME", "curator")
    start = time.monotonic()
    queue_path = workspace / "runtime" / "curator-jobs.json"
    writeback_path = workspace / "runtime" / "curator-writeback.jsonl"
    jobs = load_json(queue_path, [])
    if not isinstance(jobs, list):
        raise SystemExit("curator-jobs.json must be a list")
    claimed = []
    for job in jobs:
        if len(claimed) >= batch_size:
            break
        if isinstance(job, dict) and job.get("status", "pending") == "pending":
            job["status"] = "claimed"
            job["claimed_by"] = agent
            claimed.append(job)
    completed = 0
    canceled = 0
    failed = 0
    writebacks = []
    now = datetime.now(timezone.utc).isoformat()
    for job in claimed:
        if time.monotonic() - start >= max_runtime_seconds:
            job["status"] = "pending"
            job["error"] = "max_runtime_exceeded"
            failed += 1
            continue
        if not clean_excerpt(job):
            job["status"] = "canceled"
            job["error"] = "insufficient_content: empty excerpt"
            job["processed_at"] = now
            canceled += 1
            continue
        annotation = make_annotation(job)
        job["status"] = "done"
        job["annotation"] = annotation
        job["processed_at"] = now
        completed += 1
        writebacks.append({"job_id": job.get("id"), "annotation": annotation, "processed_at": now})
    dump_json(queue_path, jobs)
    if writebacks:
        writeback_path.parent.mkdir(parents=True, exist_ok=True)
        with writeback_path.open("a", encoding="utf-8") as handle:
            for item in writebacks:
                handle.write(json.dumps(item, sort_keys=True) + "\n")
    remaining = sum(1 for job in jobs if isinstance(job, dict) and job.get("status", "pending") == "pending")
    report = (
        f"curator batch: claimed {len(claimed)}, completed {completed}, "
        f"canceled {canceled}, failed {failed}, pending {remaining}"
    )
    send_report(report_target, agent, report)
    return 0 if failed == 0 else 1


if __name__ == "__main__":
    raise SystemExit(main())
'''


def curator_grind_runtime_source() -> str:
    return r'''#!/usr/bin/env python3
import argparse
import json
import os
import sqlite3
import subprocess
import sys
from pathlib import Path


def load_json(path, fallback):
    if not path.exists():
        return fallback
    with path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def send_report(target, author, body):
    if not target:
        return
    completed = subprocess.run(
        ["swarm", "message", "send", "--target", target, "--author", author],
        input=body,
        text=True,
        capture_output=True,
        timeout=20,
    )
    if completed.returncode == 0 and "Freshness hold:" in completed.stdout:
        completed = subprocess.run(
            ["swarm", "message", "send", "--send-draft", "--target", target, "--author", author],
            text=True,
            capture_output=True,
            timeout=20,
        )
    if completed.returncode != 0:
        sys.stderr.write(completed.stderr or completed.stdout)
        raise SystemExit(1)


def stats_for(db_path, prompt_version):
    conn = sqlite3.connect(db_path, timeout=5.0)
    conn.row_factory = sqlite3.Row
    try:
        counts = {"pending": 0, "claimed": 0, "done": 0, "failed": 0, "canceled": 0}
        for row in conn.execute(
            "SELECT status, COUNT(*) AS count FROM curator_jobs WHERE prompt_version = ? GROUP BY status",
            (prompt_version,),
        ):
            counts[str(row["status"])] = int(row["count"])
        unqueued = conn.execute(
            """
            SELECT COUNT(*) AS count
            FROM processed_cards c
            WHERE c.enriched_at IS NULL AND c.enrich_status = 'pending'
              AND NOT EXISTS (
                SELECT 1 FROM curator_jobs j
                WHERE j.card_id = c.id AND j.prompt_version = ?
              )
            """,
            (prompt_version,),
        ).fetchone()["count"]
        counts["unqueued"] = int(unqueued)
        return counts
    finally:
        conn.close()


def fmt_stats(stats):
    return (
        f"unqueued={stats['unqueued']} pending={stats['pending']} claimed={stats['claimed']} "
        f"done={stats['done']} failed={stats['failed']} canceled={stats['canceled']}"
    )


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--resume", default="")
    args = parser.parse_args()
    del args
    workspace = Path.cwd()
    config = load_json(workspace / "runtime" / "curator-config.json", {})
    report_target = str(config.get("report_target") or "")
    agent = os.environ.get("SWARM_AGENT_NAME", "curator")
    server_dir = Path(str(config.get("grind_server") or "")).expanduser()
    db_path = Path(str(config.get("grind_db_path") or "")).expanduser()
    prompt_version = str(config.get("prompt_version") or "curator-v3")
    batch_size = int(config.get("batch_size", 10))
    queue_fill_limit = int(config.get("queue_fill_limit", max(batch_size, 10)))
    max_runtime_seconds = float(config.get("max_runtime_seconds", 300))
    if not server_dir.exists():
        raise SystemExit(f"grind server path missing: {server_dir}")
    if not db_path.exists():
        raise SystemExit(f"grind db path missing: {db_path}")

    before = stats_for(db_path, prompt_version)
    env = os.environ.copy()
    env.update(
        {
            "GW_DB_PATH": str(db_path),
            "CURATOR_WORKER_ID": agent,
            "CURATOR_BATCH": str(batch_size),
            "CURATOR_QUEUE_FILL_LIMIT": str(queue_fill_limit),
            "CURATOR_PROMPT_VERSION": prompt_version,
            "CURATOR_AGENT_WORKSPACE": str(workspace / "runtime" / "grind-codex-workspace"),
            "CURATOR_CODEX_TIMEOUT_MS": str(max(1000, int(max_runtime_seconds * 1000))),
        }
    )
    for key, env_key in (
        ("codex_bin", "CURATOR_CODEX_BIN"),
        ("codex_model", "CURATOR_CODEX_MODEL"),
        ("codex_home", "CODEX_HOME"),
    ):
        value = config.get(key)
        if value:
            env[env_key] = str(value)
    env.pop("CURATOR_LOOP", None)
    timed_out = False
    completed = None
    spawn_error = ""
    try:
        completed = subprocess.run(
            ["npm", "run", "curator:codex", "--silent"],
            cwd=server_dir,
            env=env,
            text=True,
            capture_output=True,
            timeout=max_runtime_seconds,
            check=False,
        )
        worker_exit = int(completed.returncode)
    except subprocess.TimeoutExpired:
        timed_out = True
        worker_exit = 124
    except OSError as exc:
        spawn_error = type(exc).__name__
        worker_exit = 127
    after = stats_for(db_path, prompt_version)
    delta = {key: after.get(key, 0) - before.get(key, 0) for key in after}
    contract_violations = max(0, delta.get("failed", 0))
    effective_exit = worker_exit if worker_exit != 0 else (2 if contract_violations else 0)
    report = (
        f"grind curator batch: true_db=1 prompt={prompt_version} worker=@{agent} "
        f"exit={worker_exit} violations={contract_violations}\n"
        f"before {fmt_stats(before)}\n"
        f"after {fmt_stats(after)}\n"
        f"delta done={delta.get('done', 0)} failed={delta.get('failed', 0)} "
        f"canceled={delta.get('canceled', 0)} pending={delta.get('pending', 0)} "
        f"unqueued={delta.get('unqueued', 0)}"
    )
    if timed_out:
        report += "\nworker_status=timeout"
    elif spawn_error:
        report += "\nworker_status=spawn_failed"
    elif worker_exit != 0:
        report += "\nworker_status=nonzero"
    elif contract_violations:
        report += "\nworker_status=failed_jobs"
    send_report(report_target, agent, report)
    if timed_out:
        sys.stderr.write("curator worker timed out\n")
    elif spawn_error:
        sys.stderr.write(f"curator worker spawn failed: {spawn_error}\n")
    elif completed is not None and worker_exit != 0:
        sys.stderr.write(completed.stderr or completed.stdout)
    elif contract_violations:
        sys.stderr.write("curator worker produced failed jobs\n")
    return effective_exit


if __name__ == "__main__":
    raise SystemExit(main())
'''


