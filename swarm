def current_timestamp() -> str:
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")


def parse_duration(value: str) -> timedelta | None:
    if len(value) < 2:
        return None
    amount_text, unit = value[:-1], value[-1]
    if not amount_text.isdigit():
        return None
    amount = int(amount_text)
    if unit == "s":
        return timedelta(seconds=amount)
    if unit == "m":
        return timedelta(minutes=amount)
    if unit == "h":
        return timedelta(hours=amount)
    if unit == "d":
        return timedelta(days=amount)
    return None


def normalize_datetime_text(value: str) -> str:
    raw = value.strip()
    if not raw:
        return raw
    try:
        parsed = datetime.fromisoformat(raw.replace("Z", "+00:00"))
    except ValueError:
        return raw
    return parsed.strftime("%Y-%m-%d %H:%M:%S")


def schedule_time_from_args(argv: list[str], absolute_flag: str = "--at", relative_flag: str = "--in") -> str | None:
    absolute = arg_value(argv, absolute_flag)
    if absolute:
        return normalize_datetime_text(absolute)
    relative = arg_value(argv, relative_flag)
    if relative:
        delta = parse_duration(relative)
        if delta is None:
            return None
        return (datetime.now() + delta).strftime("%Y-%m-%d %H:%M:%S")
    return None


def parse_state_datetime(value: str) -> datetime | None:
    try:
        return datetime.strptime(value, "%Y-%m-%d %H:%M:%S")
    except ValueError:
        normalized = normalize_datetime_text(value)
        try:
            return datetime.strptime(normalized, "%Y-%m-%d %H:%M:%S")
        except ValueError:
            return None


