    return None


def bounded_records(records: list[dict[str, Any]], argv: list[str], limit: int = 20) -> tuple[list[dict[str, Any]], str | None]:
    before = arg_value(argv, "--before")
    after = arg_value(argv, "--after")
    around = arg_value(argv, "--around")
    anchors = [value for value in (before, after, around) if value is not None]
    if len(anchors) > 1:
        return [], "use only one of --before, --after, or --around"
    if before is not None:
        seq = anchor_seq(records, before)
        if seq is None:
            return [], f"anchor not found: {before}"
        return [record for record in records if int(record["seq"]) < seq][-limit:], None
    if after is not None:
        seq = anchor_seq(records, after)
        if seq is None:
            return [], f"anchor not found: {after}"
        return [record for record in records if int(record["seq"]) > seq][:limit], None
    if around is not None:
        seq = anchor_seq(records, around)
        if seq is None:
            return [], f"anchor not found: {around}"
        ordered = sorted(records, key=lambda row: abs(int(row["seq"]) - seq))
        selected = sorted(ordered[: min(limit, len(ordered))], key=lambda row: int(row["seq"]))
        return selected, None
    return records[-limit:], None


def parse_read_limit(argv: list[str]) -> tuple[int, str | None]:
    raw = arg_value(argv, "--limit")
    if raw is None:
        return 20, None
    try:
        value = int(raw)
    except ValueError:
        return 0, "--limit must be a positive integer"
    if value < 1:
        return 0, "--limit must be a positive integer"
    if value > 200:
        return 0, "--limit must be at most 200"
    return value, None


def write_stdout(text: str) -> int:
