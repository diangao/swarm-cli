def parse_after_seq(argv: list[str]) -> tuple[int, str | None]:
    raw = arg_value(argv, "--after-seq")
    if raw is None:
        return 0, None
    try:
        value = int(raw)
    except ValueError:
        return 0, "--after-seq must be a non-negative integer"
    if value < 0:
        return 0, "--after-seq must be a non-negative integer"
    return value, None


def parse_timeout_seconds(argv: list[str]) -> tuple[float, str | None]:
    raw = arg_value(argv, "--timeout-seconds")
    if raw is None:
        return 10.0, None
    try:
        value = float(raw)
    except ValueError:
        return 0.0, "--timeout-seconds must be a positive number"
    if value <= 0 or value > 120:
        return 0.0, "--timeout-seconds must be between 0 and 120"
    return value, None


def slack_outbound_plans_from_state(
    state: dict[str, Any],
    workspace: str,
    target: str | None,
    message_ids: list[str],
    after_seq: int,
) -> tuple[list[dict[str, Any]] | None, str | None]:
    if slack_workspace_by_id(state, workspace) is None:
        return None, (
            "Error: Slack workspace config not found\n"
            "Code: NOT_FOUND\n"
            "Next action: configure it with swarm slack configure.\n"
        )
    records: list[dict[str, Any]] = []
    if message_ids:
        seen: set[str] = set()
        for msg_id in message_ids:
            record, error = message_by_id(state, msg_id)
            if error == "ambiguous":
                return None, f"Error: ambiguous message id: {msg_id}\nCode: AMBIGUOUS_ID\n"
            if record is None:
                return None, "Error: Message not found\nCode: NOT_FOUND\n"
            if target is not None and record["target"] != target:
                return None, "Error: message target does not match --target\nCode: INVALID_TARGET\n"
            if record["id"] not in seen:
                records.append(record)
                seen.add(record["id"])
    else:
        assert target is not None
        if not known_surface(state, target):
            return None, f"Error: Channel not found: {target}\nCode: NOT_FOUND\n"
        records = [
            record
            for record in state.get("messages", [])
            if record["target"] == target and int(record["seq"]) > after_seq
        ]
    if not records:
        return [], None

    plans: list[dict[str, Any]] = []
    for record in sorted(records, key=lambda row: int(row["seq"])):
        if not slack_record_needs_outbound(state, workspace, record):
            continue
        channel_mapping = known_slack_channel_mapping(state, workspace, str(record["target"]))
        if channel_mapping is None:
            return None, (
                f"Error: Slack channel mapping not found for target {channel_for_target(str(record['target']))}\n"
                "Code: NOT_FOUND\n"
                "Next action: ingest a Slack message from that channel or mark a sent root with --channel-id.\n"
            )
        plan, plan_error = slack_outbound_plan_item(state, workspace, channel_mapping, record)
        if plan_error is not None:
            return None, f"Error: {plan_error}\nCode: NOT_FOUND\n"
        assert plan is not None
        plans.append(plan)
    return plans, None


def record_slack_sent_mapping(
    state: dict[str, Any],
    workspace: str,
    msg_id: str,
    slack_ts: str,
    explicit_channel_id: str | None = None,
    explicit_channel_name: str | None = None,
) -> tuple[dict[str, Any] | None, dict[str, Any] | None, str | None, str | None]:
    if slack_workspace_by_id(state, workspace) is None:
        return None, None, None, (
            "Error: Slack workspace config not found\n"
            "Code: NOT_FOUND\n"
            "Next action: configure it with swarm slack configure.\n"
        )
    record, error = message_by_id(state, msg_id)
    if error == "ambiguous":
        return None, None, None, f"Error: ambiguous message id: {msg_id}\nCode: AMBIGUOUS_ID\n"
    if record is None:
        return None, None, None, "Error: Message not found\nCode: NOT_FOUND\n"

    existing_for_message = slack_mapping_by_message_id(state, workspace, str(record["id"]))
    if existing_for_message is not None:
        if existing_for_message["slack_ts"] == slack_ts:
            return existing_for_message, record, "already", None
        return None, None, None, (
            "Error: swarm message is already mapped to a different Slack ts\n"
            "Code: SLACK_MAPPING_CONFLICT\n"
        )

    channel_mapping = known_slack_channel_mapping(state, workspace, str(record["target"]))
    channel_id = explicit_channel_id
    channel_name = explicit_channel_name
    if channel_mapping is not None:
        channel_id = channel_id or channel_mapping["channel_id"]
        channel_name = channel_name or channel_mapping.get("channel_name")
    if channel_id is None:
        return None, None, None, (
            "Error: --channel-id is required when target has no existing Slack channel mapping\n"
            "Code: INVALID_ARG\n"
        )
    existing_for_ts = slack_mapping_by_key(state, workspace, channel_id, slack_ts)
    if existing_for_ts is not None:
        return None, None, None, (
            "Error: Slack ts is already mapped to another swarm message\n"
            "Code: SLACK_TS_CONFLICT\n"
        )
    thread_ts, thread_error = slack_thread_ts_for_target(state, workspace, str(record["target"]))
    if thread_error is not None:
        return None, None, None, f"Error: {thread_error}\nCode: NOT_FOUND\n"
    mapping = slack_message_item(
        workspace,
        channel_id,
        channel_name,
        slack_ts,
        thread_ts,
        record["target"],
        record["id"],
        current_timestamp(),
    )
    state.setdefault("slack_messages", []).append(mapping)
    return mapping, record, "recorded", None


def command_slack_outbound(argv: list[str]) -> int:
    if (
        flag_missing_value(argv, "--workspace")
        or flag_missing_value(argv, "--target")
        or flag_missing_value(argv, "--message-id")
        or flag_missing_value(argv, "--after-seq")
    ):
        return write_stderr("Error: Slack outbound flags require values\nCode: INVALID_ARG\n")
    workspace = arg_value(argv, "--workspace")
    target = arg_value(argv, "--target")
    message_ids = arg_values(argv, "--message-id")
    after_seq, seq_error = parse_after_seq(argv)
    if seq_error is not None:
        return write_stderr(f"Error: {seq_error}\nCode: INVALID_ARG\n")
    if not workspace:
        return write_stderr("Error: --workspace is required\nCode: INVALID_ARG\n")
    if target is None and not message_ids:
        return write_stderr("Error: --target or --message-id is required\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        plans, plan_error = slack_outbound_plans_from_state(state, workspace, target, message_ids, after_seq)
        if plan_error is not None:
            return write_stderr(plan_error)
        assert plans is not None
        if not plans:
            return write_stdout("## Slack Outbound Plan (0 requests)\n\nNo outbound messages.\n")
        rendered = "\n".join(json.dumps(plan, sort_keys=True, separators=(",", ":")) for plan in plans)
        return write_stdout(
            f"## Slack Outbound Plan ({len(plans)} requests)\n\n"
            f"{rendered}\n\n"
            "No network request was sent; this is a render plan from canonical swarm state.\n"
        )

    return with_read_state(action)


def read_slack_mock_responses(path_value: str | None, plan_count: int) -> tuple[list[dict[str, Any]] | None, str | None]:
    if path_value is None:
        return None, None
    path = Path(path_value).expanduser()
    try:
        raw = path.read_text()
    except OSError:
        return None, f"Slack mock response file not found: {path_value}"
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError:
        return None, "invalid Slack mock response JSON"
    if isinstance(payload, dict):
        responses = [payload]
    elif isinstance(payload, list) and all(isinstance(item, dict) for item in payload):
        responses = payload
    else:
        return None, "Slack mock response JSON must be an object or list of objects"
    if len(responses) != plan_count:
        return None, "Slack mock response count must match outbound plan count"
    return responses, None


def command_slack_send(argv: list[str]) -> int:
    if (
        flag_missing_value(argv, "--workspace")
        or flag_missing_value(argv, "--target")
        or flag_missing_value(argv, "--message-id")
        or flag_missing_value(argv, "--after-seq")
        or flag_missing_value(argv, "--mock-response-file")
        or flag_missing_value(argv, "--timeout-seconds")
    ):
        return write_stderr("Error: Slack send flags require values\nCode: INVALID_ARG\n")
    workspace = arg_value(argv, "--workspace")
    target = arg_value(argv, "--target")
    message_ids = arg_values(argv, "--message-id")
    mock_response_file = arg_value(argv, "--mock-response-file")
    after_seq, seq_error = parse_after_seq(argv)
    if seq_error is not None:
        return write_stderr(f"Error: {seq_error}\nCode: INVALID_ARG\n")
    timeout_seconds, timeout_error = parse_timeout_seconds(argv)
    if timeout_error is not None:
        return write_stderr(f"Error: {timeout_error}\nCode: INVALID_ARG\n")
    if not workspace:
        return write_stderr("Error: --workspace is required\nCode: INVALID_ARG\n")
    if target is None and not message_ids:
        return write_stderr("Error: --target or --message-id is required\nCode: INVALID_ARG\n")

    context: dict[str, Any] = {}

    def plan_action(state: dict[str, Any]) -> int:
        config = slack_workspace_by_id(state, workspace)
        if config is None:
            return write_stderr(
                "Error: Slack workspace config not found\n"
                "Code: NOT_FOUND\n"
                "Next action: configure it with swarm slack configure.\n"
            )
        plans, plan_error = slack_outbound_plans_from_state(state, workspace, target, message_ids, after_seq)
        if plan_error is not None:
            return write_stderr(plan_error)
        assert plans is not None
        token_env = config["bot_token_env"]
        context["plans"] = deepcopy(plans)
        context["token_env"] = token_env
        if plans:
            token_value = os.environ.get(token_env)
            if not token_value:
                return write_stderr(
                    "Error: Slack bot token environment variable is not set\n"
                    "Code: SLACK_TOKEN_MISSING\n"
                    f"Next action: set {token_env} in the adapter process environment.\n"
                )
            context["token_value"] = token_value
        return 0

    result = with_read_state(plan_action)
    if result != 0:
        return result
    plans = context.get("plans", [])
    assert isinstance(plans, list)
    if not plans:
        return write_stdout("## Slack Send (0 requests)\n\nNo outbound messages.\n")

    mock_responses, mock_error = read_slack_mock_responses(mock_response_file, len(plans))
    if mock_error is not None:
        return write_stderr(f"Error: {mock_error}\nCode: INVALID_ARG\n")

    rows: list[str] = []
    for index, plan in enumerate(plans):
        message_id = str(plan["swarm_message_id"])

        def preflight_action(state: dict[str, Any]) -> int:
            if slack_mapping_by_message_id(state, workspace, message_id) is not None:
                return write_stderr(
                    "Error: swarm message was mapped before send; refusing duplicate Slack post\n"
                    "Code: SLACK_MAPPING_CONFLICT\n"
                )
            return 0

        preflight = with_read_state(preflight_action)
        if preflight != 0:
            return preflight

        if mock_responses is not None:
            response, response_error = parse_slack_send_response(mock_responses[index], plan)
        else:
            response, response_error = slack_web_post_message(context["token_value"], plan, timeout_seconds)
        if response_error is not None:
            return write_stderr(f"Error: {response_error}\nCode: SLACK_SEND_FAILED\n")
        assert response is not None

        record_context: dict[str, Any] = {}

        def mark_action(state: dict[str, Any]) -> int:
            mapping, record, status, mark_error = record_slack_sent_mapping(
                state,
                workspace,
                message_id,
                response["ts"],
                response["channel"],
            )
            if mark_error is not None:
                return write_stderr(mark_error)
            assert mapping is not None and record is not None and status is not None
            record_context["status"] = status
            record_context["message_id"] = record["id"]
            record_context["target"] = record["target"]
            record_context["channel"] = mapping["channel_id"]
            record_context["ts"] = mapping["slack_ts"]
            return 0

        marked = with_mutable_state(mark_action)
        if marked != 0:
            return marked
        rows.append(
            f"- {record_context['message_id']} {record_context['target']} -> "
            f"{record_context['channel']} ts={record_context['ts']} ({record_context['status']})"
        )

    mode_line = "Mock Slack responses used; no network request was sent." if mock_responses is not None else "Slack Web API chat.postMessage was called."
    return write_stdout(
        f"## Slack Send ({len(rows)} requests)\n\n"
        + "\n".join(rows)
        + "\n\n"
        f"Token source: {context['token_env']} (value not shown)\n"
        f"{mode_line}\n"
        "Successful responses were recorded through the mark-sent ledger.\n"
    )


def parse_slack_limit(argv: list[str]) -> tuple[int, str | None]:
    raw = arg_value(argv, "--limit")
    if raw is None:
        return 100, None
    try:
        value = int(raw)
    except ValueError:
        return 0, "--limit must be a positive integer"
    if value <= 0 or value > 1000:
        return 0, "--limit must be between 1 and 1000"
    return value, None


def parse_bool_flag(argv: list[str], flag: str) -> bool:
    return flag in argv


def parse_slack_mock_api(path_value: str | None) -> tuple[dict[str, Any] | None, str | None]:
    if path_value is None:
        return None, None
    path = Path(path_value).expanduser()
    try:
        raw = path.read_text()
    except OSError:
        return None, f"Slack mock API file not found: {path_value}"
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError:
        return None, "invalid Slack mock API JSON"
    if not isinstance(payload, dict):
        return None, "Slack mock API JSON must be an object"
    histories = payload.get("histories")
    replies = payload.get("replies")
    if histories is not None and not isinstance(histories, dict):
        return None, "Slack mock API histories must be an object"
    if replies is not None and not isinstance(replies, dict):
        return None, "Slack mock API replies must be an object"
    return payload, None


def slack_history_mock_response(
    mock_api: dict[str, Any],
    method_name: str,
    payload: dict[str, Any],
) -> tuple[dict[str, Any] | None, str | None]:
    if method_name == "conversations.history":
        histories = mock_api.get("histories", {})
        assert isinstance(histories, dict)
        channel_id = payload.get("channel")
        response = histories.get(channel_id)
    elif method_name == "conversations.replies":
        replies = mock_api.get("replies", {})
        assert isinstance(replies, dict)
        channel_id = payload.get("channel")
        thread_ts = payload.get("ts")
        response = replies.get(f"{channel_id}:{thread_ts}")
    else:
        response = None
    if response is None:
        return {"ok": True, "messages": [], "has_more": False}, None
    if not isinstance(response, dict):
        return None, "Slack mock API response must be an object"
    if response.get("ok") is not True:
        reason = response.get("error") if isinstance(response.get("error"), str) else "unknown_error"
        return None, f"Slack mock API rejected {method_name}: {reason}"
    return deepcopy(response), None


def slack_history_api_call(
    token: str,
    method_name: str,
    payload: dict[str, Any],
    timeout_seconds: float,
    mock_api: dict[str, Any] | None,
) -> tuple[dict[str, Any] | None, str | None]:
    if mock_api is not None:
        return slack_history_mock_response(mock_api, method_name, payload)
    return slack_web_api_call(token, method_name, payload, timeout_seconds)


def slack_history_messages_from_response(response: dict[str, Any]) -> tuple[list[dict[str, Any]] | None, str | None]:
    messages = response.get("messages")
    if not isinstance(messages, list):
        return None, "Slack Web API response missing messages list"
    normalized: list[dict[str, Any]] = []
    for message in messages:
        if not isinstance(message, dict):
            return None, "Slack Web API messages must be objects"
        if not valid_slack_ts(message.get("ts")):
            return None, "Slack Web API message had invalid ts"
        normalized.append(message)
    return normalized, None


def slack_history_next_cursor(response: dict[str, Any]) -> str | None:
    metadata = response.get("response_metadata")
    if not isinstance(metadata, dict):
        return None
    cursor = metadata.get("next_cursor")
    if isinstance(cursor, str) and cursor.strip():
        return cursor.strip()
    return None


def command_slack_export_history(argv: list[str]) -> int:
    if (
        flag_missing_value(argv, "--workspace")
        or flag_missing_value(argv, "--channel-id")
        or flag_missing_value(argv, "--channel-name")
        or flag_missing_value(argv, "--limit")
        or flag_missing_value(argv, "--oldest")
        or flag_missing_value(argv, "--latest")
        or flag_missing_value(argv, "--timeout-seconds")
        or flag_missing_value(argv, "--mock-api-file")
    ):
        return write_stderr("Error: Slack export-history flags require values\nCode: INVALID_ARG\n")
    workspace = arg_value(argv, "--workspace")
    channel_id = arg_value(argv, "--channel-id")
    channel_name = arg_value(argv, "--channel-name")
    oldest = arg_value(argv, "--oldest")
    latest = arg_value(argv, "--latest")
    include_replies = parse_bool_flag(argv, "--include-replies")
    limit, limit_error = parse_slack_limit(argv)
    if limit_error is not None:
        return write_stderr(f"Error: {limit_error}\nCode: INVALID_ARG\n")
    timeout_seconds, timeout_error = parse_timeout_seconds(argv)
    if timeout_error is not None:
        return write_stderr(f"Error: {timeout_error}\nCode: INVALID_ARG\n")
    mock_api, mock_error = parse_slack_mock_api(arg_value(argv, "--mock-api-file"))
    if mock_error is not None:
        return write_stderr(f"Error: {mock_error}\nCode: INVALID_ARG\n")
    if not workspace or not channel_id:
        return write_stderr("Error: --workspace and --channel-id are required\nCode: INVALID_ARG\n")
    if oldest is not None and not valid_slack_ts(oldest):
        return write_stderr("Error: --oldest must be a positive Slack timestamp\nCode: INVALID_ARG\n")
    if latest is not None and not valid_slack_ts(latest):
        return write_stderr("Error: --latest must be a positive Slack timestamp\nCode: INVALID_ARG\n")

    context: dict[str, Any] = {}

    def config_action(state: dict[str, Any]) -> int:
        config = slack_workspace_by_id(state, workspace)
        if config is None:
            return write_stderr(
                "Error: Slack workspace config not found\n"
                "Code: NOT_FOUND\n"
                "Next action: configure it with swarm slack configure.\n"
            )
        token_env = config["bot_token_env"]
        context["token_env"] = token_env
        if mock_api is None:
            token_value = os.environ.get(token_env)
            if not token_value:
                return write_stderr(
                    "Error: Slack bot token environment variable is not set\n"
                    "Code: SLACK_TOKEN_MISSING\n"
                    f"Next action: set {token_env} in the adapter process environment.\n"
                )
            context["token_value"] = token_value
        else:
            context["token_value"] = ""
        return 0

    configured = with_read_state(config_action)
    if configured != 0:
        return configured

    events: list[dict[str, Any]] = []
    seen_keys: set[tuple[str, str]] = set()
    skipped_messages = 0

    def append_exported_message(message: dict[str, Any]) -> tuple[bool, str | None]:
        nonlocal skipped_messages
        slack_ts = str(message["ts"])
        key = (channel_id, slack_ts)
        if key in seen_keys:
            return False, None
        payload, payload_error = slack_history_message_to_event_payload(
            workspace,
            channel_id,
            channel_name,
            message,
        )
        if payload_error is not None:
            skipped_messages += 1
            return False, None
        assert payload is not None
        # Keep the exporter honest: every emitted row must already be accepted by ingest normalization.
        _, ingest_error = normalized_slack_event(payload)
        if ingest_error is not None:
            skipped_messages += 1
            return False, None
        seen_keys.add(key)
        events.append(payload)
        return True, None

    def append_message_replies(message: dict[str, Any]) -> str | None:
        reply_cursor: str | None = None
        while True:
            reply_payload = {
                "channel": channel_id,
                "ts": message["ts"],
                "limit": 200,
            }
            if reply_cursor:
                reply_payload["cursor"] = reply_cursor
            reply_response, reply_error = slack_history_api_call(
                str(context["token_value"]),
                "conversations.replies",
                reply_payload,
                timeout_seconds,
                mock_api,
            )
            if reply_error is not None:
                return reply_error
            assert reply_response is not None
            replies, replies_error = slack_history_messages_from_response(reply_response)
            if replies_error is not None:
                return replies_error
            assert replies is not None
            for reply in sorted_slack_messages(replies):
                if str(reply["ts"]) == str(message["ts"]):
                    continue
                _, reply_append_error = append_exported_message(reply)
                if reply_append_error is not None:
                    return reply_append_error
            reply_cursor = slack_history_next_cursor(reply_response)
            if not reply_cursor or not reply_response.get("has_more"):
                break
        return None

    history_payload: dict[str, Any] = {
        "channel": channel_id,
        "limit": min(limit, 200),
    }
    if oldest is not None:
        history_payload["oldest"] = oldest
    if latest is not None:
        history_payload["latest"] = latest

    fetched = 0
    cursor: str | None = None
    while fetched < limit:
        request_payload = dict(history_payload)
        if cursor:
            request_payload["cursor"] = cursor
        response, response_error = slack_history_api_call(
            str(context["token_value"]),
            "conversations.history",
            request_payload,
            timeout_seconds,
            mock_api,
        )
        if response_error is not None:
            return write_stderr(f"Error: {response_error}\nCode: SLACK_HISTORY_FAILED\n")
        assert response is not None
        messages, messages_error = slack_history_messages_from_response(response)
        if messages_error is not None:
            return write_stderr(f"Error: {messages_error}\nCode: SLACK_HISTORY_FAILED\n")
        assert messages is not None
        for message in sorted_slack_messages(messages):
            _, append_error = append_exported_message(message)
            if append_error is not None:
                return write_stderr(f"Error: {append_error}\nCode: INVALID_SLACK_EVENT\n")
            fetched += 1
            if include_replies and message.get("reply_count"):
                reply_error = append_message_replies(message)
                if reply_error is not None:
                    return write_stderr(f"Error: {reply_error}\nCode: SLACK_HISTORY_FAILED\n")
            if fetched >= limit:
                break
        cursor = slack_history_next_cursor(response)
        if not cursor or not response.get("has_more"):
            break

    rendered = "\n".join(
        json.dumps(event, sort_keys=True, separators=(",", ":"))
        for event in sorted(
            events,
            key=lambda payload: float(str(slack_event_envelope(payload)["ts"])),
        )
    )
    sys.stderr.write(
        f"Exported {len(events)} Slack event JSON rows from {channel_id}.\n"
        "Read-only export; swarm SQLite state was not modified.\n"
        f"Token source: {context['token_env']} (value not shown).\n"
    )
    if skipped_messages:
        sys.stderr.write(f"Skipped {skipped_messages} history rows not accepted by current ingest.\n")
    if mock_api is not None:
        sys.stderr.write("Mock Slack API responses used; no network request was sent.\n")
    return write_stdout(rendered + ("\n" if rendered else ""))


def command_slack_mark_sent(argv: list[str]) -> int:
    if (
        flag_missing_value(argv, "--workspace")
        or flag_missing_value(argv, "--message-id")
        or flag_missing_value(argv, "--ts")
        or flag_missing_value(argv, "--channel-id")
        or flag_missing_value(argv, "--channel-name")
    ):
        return write_stderr("Error: Slack mark-sent flags require values\nCode: INVALID_ARG\n")
    workspace = arg_value(argv, "--workspace")
    msg_id = arg_value(argv, "--message-id")
    slack_ts = arg_value(argv, "--ts")
    explicit_channel_id = arg_value(argv, "--channel-id")
    explicit_channel_name = arg_value(argv, "--channel-name")
    if not workspace or not msg_id or not slack_ts:
        return write_stderr("Error: --workspace, --message-id, and --ts are required\nCode: INVALID_ARG\n")
    if state_time_from_slack_ts(slack_ts) is None:
        return write_stderr("Error: --ts must be a positive Slack timestamp\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        mapping, record, status, error = record_slack_sent_mapping(
            state,
            workspace,
            msg_id,
            slack_ts,
            explicit_channel_id,
            explicit_channel_name,
        )
        if error is not None:
            return write_stderr(error)
        assert mapping is not None and record is not None
        heading = "Slack sent mapping already recorded." if status == "already" else "Slack sent mapping recorded."
        return write_stdout(slack_mapping_output(mapping, record, heading))

    return with_mutable_state(action)


def command_slack(argv: list[str]) -> int:
    if not argv:
        return write_stderr("Error: missing slack subcommand\nCode: INVALID_ARG\n")
    subcommand = argv[0]
    rest = argv[1:]
    if subcommand == "configure":
        return command_slack_configure(rest)
    if subcommand == "env":
        return command_slack_env(rest)
    if subcommand == "ingest":
        return command_slack_ingest(rest)
    if subcommand == "resolve":
