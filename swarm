def set_all_agents_presence(presence: str) -> int:
    def action(state: dict[str, Any]) -> int:
        stamp = current_timestamp()
        for record in state.get("agents", []):
            record["presence"] = presence
            record["presence_updated_at"] = stamp
        append_daemon_event(state, "resident_presence", {"presence": presence, "agents": len(state.get("agents", []))})
        return 0

    return with_mutable_state(action)


def set_agent_presence(agent_name: str, presence: str, mark_turn: bool = False) -> int:
    def action(state: dict[str, Any]) -> int:
        for record in state.get("agents", []):
            if record["name"] == agent_name:
                record["presence"] = presence
                record["presence_updated_at"] = current_timestamp()
                if mark_turn:
                    record["last_turn_at"] = current_timestamp()
                return 0
        return 1

    return with_mutable_state(action)


def agents_with_active_wakes() -> list[str]:
    def action(state: dict[str, Any]) -> list[str]:
        names = []
        for wake in state.get("daemon_wakes", []):
            if int(wake.get("running") or 0) == 1:
                names.append(str(wake["agent_name"]))
        return names

    return with_read_state(action)


def pending_outbound_targets(workspace: str) -> list[str]:
    def action(state: dict[str, Any]) -> list[str]:
        if slack_workspace_by_id(state, workspace) is None:
            return []
        targets: list[str] = []
        for record in state.get("messages", []):
            if not slack_record_needs_outbound(state, workspace, record):
                continue
            target = str(record["target"])
            if target in targets:
                continue
            if known_slack_channel_mapping(state, workspace, target) is None:
                continue
            targets.append(target)
        return targets

    return with_read_state(action)


def command_daemon_resident(argv: list[str]) -> int:
    unknown = unknown_flags(
        argv,
        {"--workspace", "--mock-socket-file", "--loops", "--idle-interval", "--turn-timeout", "--socket-window", "--max-events"},
    )
    if unknown:
        return write_stderr(f"Error: unknown daemon resident flag: {unknown[0]}\nCode: INVALID_ARG\n")
    for flag in ("--workspace", "--mock-socket-file", "--loops", "--idle-interval", "--turn-timeout", "--socket-window", "--max-events"):
        if flag_missing_value(argv, flag):
            return write_stderr(f"Error: {flag} requires a value\nCode: INVALID_ARG\n")
    workspace = arg_value(argv, "--workspace")
    mock_file = arg_value(argv, "--mock-socket-file")
    loops = 0
    loops_text = arg_value(argv, "--loops")
    if loops_text is not None:
        try:
            loops = int(loops_text)
        except ValueError:
            loops = -1
        if loops <= 0:
            return write_stderr("Error: --loops must be a positive integer\nCode: INVALID_ARG\n")
    idle_interval = parse_duration(arg_value(argv, "--idle-interval") or "5s")
    if idle_interval is None or idle_interval.total_seconds() < 0:
        return write_stderr("Error: --idle-interval must be a duration like 5s, 1m, 1h, or 1d\nCode: INVALID_ARG\n")
    turn_timeout = parse_duration(arg_value(argv, "--turn-timeout") or "5m")
    if turn_timeout is None or turn_timeout.total_seconds() <= 0:
        return write_stderr("Error: --turn-timeout must be a positive duration like 5s, 1m, 1h, or 1d\nCode: INVALID_ARG\n")
    socket_window = arg_value(argv, "--socket-window") or "20s"
    max_events = arg_value(argv, "--max-events") or "10"

    set_all_agents_presence("idle")
    daemon_record_event("resident_started", {"loops": loops, "workspace": workspace or ""})
    iterations = 0
    turns_run = 0
    mock_consumed = False
    failure_streaks: dict[str, int] = {}
    quarantined: set[str] = set()
    socket_thread: threading.Thread | None = None
    socket_thread_lost = False
    if workspace and mock_file is None:
        # The live Socket Mode loop never returns while the connection is
        # healthy, so it owns a background thread; the scheduler loop below
        # keeps running reminders and wake consumption in parallel. Both
        # sides serialize through per-call SQLite connections.
        socket_thread = threading.Thread(
            target=command_daemon_slack,
            args=(["--workspace", workspace, "--socket-timeout", socket_window],),
            name="slack-socket-loop",
            daemon=True,
        )
        socket_thread.start()
    try:
        while loops == 0 or iterations < loops:
            iterations += 1
            if workspace and mock_file and not mock_consumed:
                mock_consumed = True
                command_daemon_slack(["--workspace", workspace, "--mock-socket-file", mock_file])
            if socket_thread is not None and not socket_thread.is_alive() and not socket_thread_lost:
                socket_thread_lost = True
                daemon_record_event("resident_socket_thread_exited", {"workspace": workspace or ""})
            process_due_reminders_once()
            for agent_name in agents_with_active_wakes():
                if agent_name in quarantined:
                    continue
                set_agent_presence(agent_name, "in_turn")
                result = execute_daemon_turn(agent_name, None, None, None, None, None, turn_timeout.total_seconds())
                set_agent_presence(agent_name, "idle", mark_turn=True)
                turns_run += 1
                if result.get("ok"):
                    failure_streaks[agent_name] = 0
                else:
                    failure_streaks[agent_name] = failure_streaks.get(agent_name, 0) + 1
                    if failure_streaks[agent_name] >= 3:
                        quarantined.add(agent_name)
                        daemon_record_event("resident_agent_quarantined", {"agent": agent_name, "failures": failure_streaks[agent_name]})
                daemon_record_event(
                    "resident_turn",
                    {
                        "agent": agent_name,
                        "ok": bool(result.get("ok")),
                        "turn_id": result.get("turn_id"),
                        "error": result.get("error") or result.get("raw_error"),
                    },
                )
            if workspace and mock_file is None:
                for outbound_target in pending_outbound_targets(workspace):
                    send_result = command_slack_send(["--workspace", workspace, "--target", outbound_target])
                    daemon_record_event(
                        "resident_outbound",
                        {"target": outbound_target, "exit": send_result},
                    )
            if idle_interval.total_seconds() > 0 and (loops == 0 or iterations < loops):
                time.sleep(idle_interval.total_seconds())
    except KeyboardInterrupt:
        pass
    finally:
        set_all_agents_presence("offline")
        daemon_record_event("resident_stopped", {"iterations": iterations, "turns": turns_run})
    return write_stdout(f"Resident daemon stopped after {iterations} iteration(s), {turns_run} turn(s).\n")


