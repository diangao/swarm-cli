def state_dir() -> Path:
    configured = os.environ.get("SWARM_CANDIDATE_STATE_DIR")
    if configured:
        return Path(configured)
    state_home = os.environ.get("XDG_STATE_HOME")
    base = Path(state_home) if state_home else Path.home() / ".local" / "state"
    return base / "swarm-cli"


def state_path() -> Path:
    return state_dir() / STATE_FILE


def attachment_root() -> Path:
    return state_dir() / "attachments"


def profile_avatar_root() -> Path:
    return state_dir() / "profile-avatars"


def seed_state() -> dict[str, Any]:
    return deepcopy(SEED_STATE)


def empty_state() -> dict[str, Any]:
    return deepcopy(EMPTY_STATE)


def should_seed_fixtures() -> bool:
    return os.environ.get("SWARM_CANDIDATE_SEED_FIXTURES") == "1"


def initial_state() -> dict[str, Any]:
    if should_seed_fixtures():
        return seed_state()
    return empty_state()


def connect_state() -> sqlite3.Connection:
    root = state_dir()
    root.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(state_path(), timeout=5.0)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA busy_timeout = 5000")
    conn.execute("PRAGMA journal_mode = WAL")
    return conn


def create_schema(conn: sqlite3.Connection) -> None:
    conn.executescript(
        """
        CREATE TABLE IF NOT EXISTS meta (
            key TEXT PRIMARY KEY,
            value TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS messages (
            seq INTEGER PRIMARY KEY,
            target TEXT NOT NULL,
            id TEXT NOT NULL UNIQUE,
            time TEXT NOT NULL,
            type TEXT NOT NULL,
            author TEXT NOT NULL,
            body TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS inbox (
            ordinal INTEGER PRIMARY KEY AUTOINCREMENT,
            kind TEXT NOT NULL CHECK (kind IN ('remote', 'local')),
            target TEXT NOT NULL,
            message_id TEXT NOT NULL,
            time TEXT NOT NULL,
            type TEXT NOT NULL,
            author TEXT NOT NULL,
            body TEXT NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_inbox_kind_ordinal ON inbox(kind, ordinal);
        CREATE TABLE IF NOT EXISTS slack_workspaces (
            workspace TEXT PRIMARY KEY,
            bot_token_env TEXT NOT NULL,
            signing_secret_env TEXT,
            app_token_env TEXT,
            mode TEXT NOT NULL,
            created_at TEXT NOT NULL,
            updated_at TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS agents (
            name TEXT PRIMARY KEY,
            display_name TEXT NOT NULL,
            runtime TEXT NOT NULL,
            workspace_path TEXT NOT NULL,
            capabilities_json TEXT NOT NULL,
            avatar_url TEXT,
            created_at TEXT NOT NULL,
            updated_at TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS agent_heartbeats (
            name TEXT PRIMARY KEY,
            status TEXT NOT NULL,
            pid TEXT,
            session_id TEXT,
            detail TEXT,
            updated_at TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS slack_messages (
            workspace TEXT NOT NULL,
            channel_id TEXT NOT NULL,
            channel_name TEXT,
            slack_ts TEXT NOT NULL,
            thread_ts TEXT,
            target TEXT NOT NULL,
            message_id TEXT NOT NULL,
            created_at TEXT NOT NULL,
            PRIMARY KEY (workspace, channel_id, slack_ts)
        );
        CREATE INDEX IF NOT EXISTS idx_slack_messages_message
            ON slack_messages(message_id);
        CREATE INDEX IF NOT EXISTS idx_slack_messages_thread
            ON slack_messages(workspace, channel_id, thread_ts);
        CREATE TABLE IF NOT EXISTS freshness (
            target TEXT PRIMARY KEY,
            cursor INTEGER NOT NULL,
            draft TEXT
        );
        CREATE TABLE IF NOT EXISTS last_read (
            target TEXT PRIMARY KEY,
            seq INTEGER NOT NULL
        );
        CREATE TABLE IF NOT EXISTS tasks (
            number INTEGER PRIMARY KEY,
            channel TEXT NOT NULL,
            title TEXT NOT NULL,
            status TEXT NOT NULL,
            creator TEXT NOT NULL,
            assignee TEXT,
            message_id TEXT NOT NULL,
            created_at TEXT NOT NULL,
            updated_at TEXT NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_tasks_channel_number ON tasks(channel, number);
        CREATE TABLE IF NOT EXISTS reminders (
            id TEXT PRIMARY KEY,
            title TEXT NOT NULL,
            target TEXT,
            status TEXT NOT NULL,
            next_fire_at TEXT NOT NULL,
            recurrence TEXT,
            created_at TEXT NOT NULL,
            updated_at TEXT NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_reminders_status_next ON reminders(status, next_fire_at);
        CREATE TABLE IF NOT EXISTS reminder_events (
            ordinal INTEGER PRIMARY KEY AUTOINCREMENT,
            reminder_id TEXT NOT NULL,
            time TEXT NOT NULL,
            event TEXT NOT NULL,
            detail TEXT NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_reminder_events_id_ordinal
            ON reminder_events(reminder_id, ordinal);
        CREATE TABLE IF NOT EXISTS attachments (
            id TEXT PRIMARY KEY,
            channel TEXT NOT NULL,
            filename TEXT NOT NULL,
            mime_type TEXT NOT NULL,
            size_bytes INTEGER NOT NULL,
            sha256 TEXT NOT NULL,
            stored_path TEXT NOT NULL,
            created_at TEXT NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_attachments_channel_created
            ON attachments(channel, created_at);
        CREATE TABLE IF NOT EXISTS message_attachments (
            message_id TEXT NOT NULL,
            attachment_id TEXT NOT NULL,
            ordinal INTEGER NOT NULL,
            PRIMARY KEY (message_id, ordinal)
        );
        CREATE INDEX IF NOT EXISTS idx_message_attachments_attachment
            ON message_attachments(attachment_id);
        CREATE TABLE IF NOT EXISTS message_reactions (
            message_id TEXT NOT NULL,
            emoji TEXT NOT NULL,
            author TEXT NOT NULL,
            created_at TEXT NOT NULL,
            PRIMARY KEY (message_id, emoji, author)
        );
        CREATE INDEX IF NOT EXISTS idx_message_reactions_message
            ON message_reactions(message_id);
        CREATE TABLE IF NOT EXISTS action_cards (
            id TEXT PRIMARY KEY,
            target TEXT NOT NULL,
            variant TEXT NOT NULL,
            payload_json TEXT NOT NULL,
            status TEXT NOT NULL,
            creator TEXT NOT NULL,
            message_id TEXT NOT NULL,
            created_at TEXT NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_action_cards_target_created
            ON action_cards(target, created_at);
        CREATE INDEX IF NOT EXISTS idx_action_cards_message
            ON action_cards(message_id);
        CREATE TABLE IF NOT EXISTS integration_services (
            name TEXT PRIMARY KEY,
            kind TEXT NOT NULL,
            description TEXT NOT NULL,
            manifest_json TEXT NOT NULL,
            requires_local_env INTEGER NOT NULL
        );
        CREATE TABLE IF NOT EXISTS integration_logins (
            service TEXT PRIMARY KEY,
            status TEXT NOT NULL,
            account TEXT NOT NULL,
            local_home TEXT NOT NULL,
            created_at TEXT NOT NULL,
            updated_at TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS channels (
            name TEXT PRIMARY KEY,
            private INTEGER NOT NULL,
            joined INTEGER NOT NULL,
            description TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS channel_members (
            channel TEXT NOT NULL,
            name TEXT NOT NULL,
            kind TEXT NOT NULL CHECK (kind IN ('agent', 'human')),
            role TEXT,
            status TEXT,
            PRIMARY KEY (channel, name)
        );
        CREATE INDEX IF NOT EXISTS idx_channel_members_channel_kind
            ON channel_members(channel, kind, name);
        CREATE TABLE IF NOT EXISTS profiles (
            name TEXT PRIMARY KEY,
            display_name TEXT NOT NULL,
            kind TEXT NOT NULL CHECK (kind IN ('agent', 'human')),
            description TEXT NOT NULL,
            avatar_url TEXT,
            avatar_file TEXT
        );
        CREATE TABLE IF NOT EXISTS thread_attention (
            target TEXT PRIMARY KEY,
            followed INTEGER NOT NULL,
            updated_at TEXT NOT NULL
        );
        """
    )


def ensure_profile_columns(conn: sqlite3.Connection) -> None:
    columns = {
        row["name"]
        for row in conn.execute("PRAGMA table_info(profiles)").fetchall()
    }
    if "avatar_url" not in columns:
        conn.execute("ALTER TABLE profiles ADD COLUMN avatar_url TEXT")
    if "avatar_file" not in columns:
        conn.execute("ALTER TABLE profiles ADD COLUMN avatar_file TEXT")


def replace_state(conn: sqlite3.Connection, state: dict[str, Any]) -> None:
    conn.execute("DELETE FROM inbox")
    conn.execute("DELETE FROM agent_heartbeats")
    conn.execute("DELETE FROM agents")
    conn.execute("DELETE FROM slack_workspaces")
    conn.execute("DELETE FROM slack_messages")
    conn.execute("DELETE FROM messages")
    conn.execute("DELETE FROM freshness")
    conn.execute("DELETE FROM last_read")
    conn.execute("DELETE FROM tasks")
    conn.execute("DELETE FROM reminder_events")
    conn.execute("DELETE FROM reminders")
    conn.execute("DELETE FROM message_attachments")
    conn.execute("DELETE FROM message_reactions")
    conn.execute("DELETE FROM action_cards")
    conn.execute("DELETE FROM integration_logins")
    conn.execute("DELETE FROM integration_services")
    conn.execute("DELETE FROM attachments")
    conn.execute("DELETE FROM channel_members")
    conn.execute("DELETE FROM channels")
    conn.execute("DELETE FROM profiles")
    conn.execute("DELETE FROM thread_attention")
    conn.execute("DELETE FROM meta")
    conn.executemany(
        "INSERT INTO meta(key, value) VALUES (?, ?)",
        [
            ("schema_version", str(SCHEMA_VERSION)),
            ("next_seq", str(int(state.get("next_seq", 1)))),
            ("next_id_counter", str(int(state.get("next_id_counter", 0)))),
            ("next_task_number", str(int(state.get("next_task_number", 1)))),
        ],
    )
    conn.executemany(
        """
        INSERT INTO messages(seq, target, id, time, type, author, body)
        VALUES (?, ?, ?, ?, ?, ?, ?)
        """,
        [
            (
                int(record["seq"]),
                record["target"],
                record["id"],
                record["time"],
                record["type"],
                record["author"],
                record["body"],
            )
            for record in state.get("messages", [])
        ],
    )
    conn.executemany(
        """
        INSERT INTO slack_messages(workspace, channel_id, channel_name, slack_ts, thread_ts, target, message_id, created_at)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?)
        """,
        [
            (
                record["workspace"],
                record["channel_id"],
                record.get("channel_name"),
                record["slack_ts"],
                record.get("thread_ts"),
                record["target"],
                record["message_id"],
                record["created_at"],
            )
            for record in state.get("slack_messages", [])
        ],
    )
