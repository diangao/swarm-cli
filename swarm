def command_task_create(argv: list[str]) -> int:
    channel = arg_value(argv, "--channel")
    if channel is None:
        return write_stderr("Error: --channel is required\nCode: INVALID_ARG\n")
    if ":" in channel or not channel.startswith("#"):
        return write_stderr("Error: tasks must be created in a top-level channel\nCode: INVALID_TARGET\n")
    title = task_title_from_args(argv)
    if title is None or not title.strip():
        return write_stderr("Error: task title is required\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        ensure_channel_catalog(state, channel)
        if not target_joined_for_write(state, channel):
            return write_stderr(f"Error: Not joined to target: {channel}\nCode: NOT_JOINED\n")
        task = append_task(state, channel, title)
        return write_stdout(
            f"Task #{task['number']} created in {channel}. "
            f"Message ID: {task['message_id']}\n"
        )

    return with_mutable_state(action)


def resolve_task_arg(state: dict[str, Any], channel: str, argv: list[str]) -> dict[str, Any] | None:
    number = arg_value(argv, "--number")
    if number is not None:
        try:
            return task_by_number(state, channel, int(number))
        except ValueError:
            return None
    message_ids = arg_values(argv, "--message-id")
    if message_ids:
        return task_by_message_id(state, channel, message_ids[0])
    return None


def command_task_claim(argv: list[str]) -> int:
    channel = arg_value(argv, "--channel")
    if channel is None:
        return write_stderr("Error: --channel is required\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        if not channel_has_task_surface(state, channel):
            return write_stderr("Error: Agent or channel not found\nCode: CLAIM_FAILED\n")
        task = resolve_task_arg(state, channel, argv)
        if task is None:
            return write_stderr("Error: Task not found\nCode: NOT_FOUND\n")
        if freshness_blockers(state, channel):
            return render_task_freshness_hold(state, channel)
        if task.get("assignee") and task["assignee"] != "candidate":
            return write_stderr(
                f"Error: task #{task['number']} is already claimed by @{task['assignee']}\n"
                "Code: CLAIM_CONFLICT\n"
            )
        task["assignee"] = "candidate"
        if task["status"] == "todo":
            task["status"] = "in_progress"
        task["updated_at"] = current_timestamp()
        return write_stdout(f"Task #{task['number']} claimed by @candidate.\n")

    return with_mutable_state(action)


def command_task_unclaim(argv: list[str]) -> int:
    channel = arg_value(argv, "--channel")
    if channel is None:
        return write_stderr("Error: --channel is required\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        if not channel_has_task_surface(state, channel):
            return write_stderr("Error: Agent or channel not found\nCode: UNCLAIM_FAILED\n")
        task = resolve_task_arg(state, channel, argv)
        if task is None:
            return write_stderr("Error: Task not found\nCode: NOT_FOUND\n")
        if freshness_blockers(state, channel):
            return render_task_freshness_hold(state, channel)
        if task["status"] == "done":
            return write_stderr("Error: done tasks cannot be unclaimed\nCode: UNCLAIM_FAILED\n")
        if task.get("assignee") != "candidate":
            return write_stderr(
                f"Error: task #{task['number']} is not claimed by @candidate\n"
                "Code: UNCLAIM_FAILED\n"
            )
        task["assignee"] = None
        task["updated_at"] = current_timestamp()
        return write_stdout(f"Task #{task['number']} unclaimed by @candidate.\n")

    return with_mutable_state(action)


def command_task_update(argv: list[str]) -> int:
    channel = arg_value(argv, "--channel")
    if channel is None:
        return write_stderr("Error: --channel is required\nCode: INVALID_ARG\n")
    status = arg_value(argv, "--status")
    if status not in TASK_STATUSES:
        return write_stderr("Error: --status must be one of todo, in_progress, in_review, done\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        if not channel_has_task_surface(state, channel):
            return write_stderr("Error: Agent or channel not found\nCode: UPDATE_FAILED\n")
        task = resolve_task_arg(state, channel, argv)
        if task is None:
            return write_stderr("Error: Task not found\nCode: NOT_FOUND\n")
        if task["status"] == status:
            return write_stderr(
                f"Error: cannot transition from {task['status']} to {status}\n"
                "Code: UPDATE_FAILED\n"
            )
        if task["status"] == "done":
            return write_stderr(
                f"Error: cannot transition from done to {status}\n"
                "Code: UPDATE_FAILED\n"
            )
        old_status = task["status"]
        task["status"] = status
        task["updated_at"] = current_timestamp()
        return write_stdout(f"Task #{task['number']} updated: {old_status} -> {status}.\n")

    return with_mutable_state(action)


def command_task(argv: list[str]) -> int:
    if not argv:
        return write_stderr("Error: missing task subcommand\nCode: INVALID_ARG\n")
    subcommand = argv[0]
    rest = argv[1:]
    if subcommand == "list":
