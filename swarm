def current_timestamp() -> str:
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")


def parse_duration(value: str) -> timedelta | None:
    if len(value) < 2:
        return None
    amount_text, unit = value[:-1], value[-1]
    if not amount_text.isdigit():
        return None
    amount = int(amount_text)
    if unit == "s":
        return timedelta(seconds=amount)
    if unit == "m":
        return timedelta(minutes=amount)
    if unit == "h":
        return timedelta(hours=amount)
    if unit == "d":
        return timedelta(days=amount)
    return None


def normalize_datetime_text(value: str) -> str:
    raw = value.strip()
    if not raw:
        return raw
    try:
        parsed = datetime.fromisoformat(raw.replace("Z", "+00:00"))
    except ValueError:
        return raw
    return parsed.strftime("%Y-%m-%d %H:%M:%S")


def schedule_time_from_args(argv: list[str], absolute_flag: str = "--at", relative_flag: str = "--in") -> str | None:
    absolute = arg_value(argv, absolute_flag)
    if absolute:
        return normalize_datetime_text(absolute)
    relative = arg_value(argv, relative_flag)
    if relative:
        delta = parse_duration(relative)
        if delta is None:
            return None
        return (datetime.now() + delta).strftime("%Y-%m-%d %H:%M:%S")
    return None


def parse_state_datetime(value: str) -> datetime | None:
    try:
        return datetime.strptime(value, "%Y-%m-%d %H:%M:%S")
    except ValueError:
        normalized = normalize_datetime_text(value)
        try:
            return datetime.strptime(normalized, "%Y-%m-%d %H:%M:%S")
        except ValueError:
            return None


def append_message(
    state: dict[str, Any],
    target: str,
    body: str,
    attachments: list[dict[str, Any]] | None = None,
    sender_type: str = "agent",
    author: str = "candidate",
    timestamp: str | None = None,
) -> dict[str, Any]:
    ensure_channel_catalog(state, target)
    attachments = attachments or []
    seq = int(state["next_seq"])
    state["next_seq"] = seq + 1
    record = message(
        seq,
        target,
        next_message_id(state),
        timestamp or current_timestamp(),
        sender_type,
        author,
        body.rstrip("\n"),
    )
    record["attachments"] = list(attachments)
    state["messages"].append(record)
    for ordinal, attachment in enumerate(attachments, start=1):
        state.setdefault("message_attachments", []).append(
            message_attachment_item(record["id"], attachment["id"], ordinal)
        )
    return record


def append_task(state: dict[str, Any], channel: str, title: str) -> dict[str, Any]:
    record = append_message(state, channel, title)
    number = int(state.get("next_task_number", 1))
    state["next_task_number"] = number + 1
    now = current_timestamp()
    task = task_item(
        number,
        channel,
        title.strip(),
        "todo",
        "candidate",
        None,
        record["id"],
        now,
        now,
    )
    state.setdefault("tasks", []).append(task)
    freshness = state.setdefault("freshness", {}).setdefault(channel, {"cursor": 0, "draft": None})
    freshness["cursor"] = record["seq"]
    return task


