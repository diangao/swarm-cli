        return write_stderr(f"Error: unknown daemon dispatch list flag: {unknown[0]}\nCode: INVALID_ARG\n")
    if flag_missing_value(argv, "--status"):
        return write_stderr("Error: daemon dispatch list flags require values\nCode: INVALID_ARG\n")
    status_filter = arg_value(argv, "--status")
    if status_filter is not None and status_filter not in {"pending", "leased", "done", "failed"}:
        return write_stderr("Error: --status must be pending, leased, done, or failed\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        items = state.get("daemon_dispatches", [])
        if status_filter is not None:
            items = [item for item in items if item["status"] == status_filter]
        lines = [
            f"- {item['id']} @{item['agent']} kind={item['kind']} status={item['status']} "
            f"attempts={item['attempts']}/{item['max_attempts']}"
            + (f" lease_owner={item['lease_owner']} lease_expires={item['lease_expires_at']}" if item["status"] == "leased" else "")
            + (f" error={item['error']}" if item.get("error") and item["status"] == "failed" else "")
            for item in items
        ]
        header = f"## Daemon Dispatches ({len(lines)})\n"
        body = "\n".join(lines) if lines else "No dispatches."
        return write_stdout(header + "\n" + body + "\n")

    return with_read_state(action)


