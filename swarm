def ensure_base_catalog(conn: sqlite3.Connection) -> None:
    for row in BASE_PROFILES:
        conn.execute(
            """
            INSERT INTO profiles(name, display_name, kind, description, avatar_url, avatar_file)
            VALUES (?, ?, ?, ?, ?, ?)
            ON CONFLICT(name) DO NOTHING
            """,
            (
                row["name"],
                row["display_name"],
                row["kind"],
                row["description"],
                row.get("avatar_url"),
                row.get("avatar_file"),
            ),
        )
    for row in BASE_INTEGRATION_SERVICES:
        conn.execute(
            """
            INSERT INTO integration_services(name, kind, description, manifest_json, requires_local_env)
            VALUES (?, ?, ?, ?, ?)
            ON CONFLICT(name) DO NOTHING
            """,
            (
                row["name"],
                row["kind"],
                row["description"],
                row["manifest_json"],
                1 if row.get("requires_local_env") else 0,
            ),
        )


def initialize_database(conn: sqlite3.Connection) -> None:
    with conn:
        create_schema(conn)
        ensure_profile_columns(conn)
        row = conn.execute("SELECT value FROM meta WHERE key = 'schema_version'").fetchone()
        if row is None:
            replace_state(conn, initial_state())
        elif row["value"] != str(SCHEMA_VERSION):
            conn.execute(
                """
                INSERT INTO meta(key, value) VALUES ('schema_version', ?)
                ON CONFLICT(key) DO UPDATE SET value = excluded.value
                """,
                (str(SCHEMA_VERSION),),
            )
        ensure_base_catalog(conn)


def meta_int(conn: sqlite3.Connection, key: str, default: int) -> int:
    row = conn.execute("SELECT value FROM meta WHERE key = ?", (key,)).fetchone()
    if row is None:
        return default
    return int(row["value"])


def inbox_rows(conn: sqlite3.Connection, kind: str) -> list[dict[str, Any]]:
    rows = conn.execute(
        """
        SELECT target, message_id, time, type, author, body
        FROM inbox
        WHERE kind = ?
        ORDER BY ordinal
        """,
        (kind,),
    ).fetchall()
    return [
        inbox_item(row["target"], row["message_id"], row["time"], row["type"], row["author"], row["body"])
        for row in rows
    ]


def decode_capabilities(value: str) -> list[str]:
    try:
        decoded = json.loads(value)
    except json.JSONDecodeError:
        return []
    if not isinstance(decoded, list):
        return []
    return [item for item in decoded if isinstance(item, str)]


def read_state(conn: sqlite3.Connection) -> dict[str, Any]:
    messages = [
        message(row["seq"], row["target"], row["id"], row["time"], row["type"], row["author"], row["body"])
        for row in conn.execute(
            "SELECT seq, target, id, time, type, author, body FROM messages ORDER BY seq"
        ).fetchall()
    ]
    slack_messages = [
        slack_message_item(
            row["workspace"],
            row["channel_id"],
            row["channel_name"],
            row["slack_ts"],
            row["thread_ts"],
            row["target"],
            row["message_id"],
            row["created_at"],
        )
        for row in conn.execute(
            """
            SELECT workspace, channel_id, channel_name, slack_ts, thread_ts, target, message_id, created_at
            FROM slack_messages
            ORDER BY workspace, channel_id, slack_ts
            """
        ).fetchall()
    ]
    slack_workspaces = [
        slack_workspace_item(
            row["workspace"],
            row["bot_token_env"],
            row["signing_secret_env"],
            row["app_token_env"],
            row["mode"],
            row["created_at"],
            row["updated_at"],
        )
        for row in conn.execute(
            """
            SELECT workspace, bot_token_env, signing_secret_env, app_token_env, mode, created_at, updated_at
            FROM slack_workspaces
            ORDER BY workspace
            """
        ).fetchall()
    ]
    agents = [
        agent_item(
            row["name"],
            row["display_name"],
            row["runtime"],
            row["workspace_path"],
            decode_capabilities(row["capabilities_json"]),
            row["avatar_url"],
            row["created_at"],
            row["updated_at"],
        )
        for row in conn.execute(
            """
            SELECT name, display_name, runtime, workspace_path, capabilities_json, avatar_url, created_at, updated_at
            FROM agents
            ORDER BY name
            """
        ).fetchall()
    ]
    agent_heartbeats = [
        agent_heartbeat_item(
            row["name"],
            row["status"],
            row["pid"],
            row["session_id"],
            row["detail"],
            row["updated_at"],
        )
        for row in conn.execute(
            """
            SELECT name, status, pid, session_id, detail, updated_at
            FROM agent_heartbeats
            ORDER BY name
            """
        ).fetchall()
    ]
    freshness = {
        row["target"]: {"cursor": row["cursor"], "draft": row["draft"]}
        for row in conn.execute("SELECT target, cursor, draft FROM freshness ORDER BY target").fetchall()
    }
    last_read = {
        row["target"]: row["seq"]
        for row in conn.execute("SELECT target, seq FROM last_read ORDER BY target").fetchall()
    }
    tasks = [
        task_item(
            row["number"],
            row["channel"],
            row["title"],
            row["status"],
            row["creator"],
            row["assignee"],
            row["message_id"],
            row["created_at"],
            row["updated_at"],
        )
        for row in conn.execute(
            """
            SELECT number, channel, title, status, creator, assignee, message_id, created_at, updated_at
            FROM tasks
            ORDER BY number
            """
        ).fetchall()
    ]
    reminders = [
        reminder_item(
            row["id"],
            row["title"],
            row["target"],
            row["status"],
            row["next_fire_at"],
            row["recurrence"],
            row["created_at"],
            row["updated_at"],
        )
        for row in conn.execute(
            """
            SELECT id, title, target, status, next_fire_at, recurrence, created_at, updated_at
            FROM reminders
            ORDER BY created_at, id
            """
        ).fetchall()
    ]
    reminder_events = [
        reminder_event_item(
            row["ordinal"],
            row["reminder_id"],
            row["time"],
            row["event"],
            row["detail"],
        )
        for row in conn.execute(
            """
            SELECT ordinal, reminder_id, time, event, detail
            FROM reminder_events
            ORDER BY ordinal
            """
        ).fetchall()
    ]
    attachments = [
        attachment_item(
            row["id"],
            row["channel"],
            row["filename"],
            row["mime_type"],
            row["size_bytes"],
            row["sha256"],
            row["stored_path"],
            row["created_at"],
        )
        for row in conn.execute(
            """
            SELECT id, channel, filename, mime_type, size_bytes, sha256, stored_path, created_at
            FROM attachments
            ORDER BY created_at, id
            """
        ).fetchall()
    ]
    message_attachments = [
        message_attachment_item(row["message_id"], row["attachment_id"], row["ordinal"])
        for row in conn.execute(
            """
            SELECT message_id, attachment_id, ordinal
            FROM message_attachments
            ORDER BY message_id, ordinal
            """
        ).fetchall()
    ]
    attachments_by_id = {record["id"]: record for record in attachments}
    links_by_message: dict[str, list[dict[str, Any]]] = {}
    for link in message_attachments:
        attachment = attachments_by_id.get(link["attachment_id"])
        if attachment is None:
            continue
        links_by_message.setdefault(link["message_id"], []).append(attachment)
    for record in messages:
        record["attachments"] = links_by_message.get(record["id"], [])
    message_reactions = [
        message_reaction_item(row["message_id"], row["emoji"], row["author"], row["created_at"])
        for row in conn.execute(
            """
            SELECT message_id, emoji, author, created_at
            FROM message_reactions
            ORDER BY message_id, emoji, created_at, author
            """
        ).fetchall()
    ]
    reactions_by_message: dict[str, list[dict[str, Any]]] = {}
    for reaction in message_reactions:
        reactions_by_message.setdefault(reaction["message_id"], []).append(reaction)
    for record in messages:
        record["reactions"] = reactions_by_message.get(record["id"], [])
    action_cards = [
        action_card_item(
            row["id"],
            row["target"],
            row["variant"],
            row["payload_json"],
