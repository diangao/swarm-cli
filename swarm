def resolve_message_attachments(
    state: dict[str, Any], target: str, attachment_ids: list[str]
) -> tuple[list[dict[str, Any]], str | None]:
    records: list[dict[str, Any]] = []
    seen: set[str] = set()
    for attachment_id in attachment_ids:
        if attachment_id in seen:
            continue
        seen.add(attachment_id)
        record = attachment_by_id(state, attachment_id)
        if record is None:
            return [], "Attachment not found"
        if not attachment_allowed_for_target(record, target):
            return [], f"Attachment {attachment_id} is not available for target {target}"
        records.append(record)
    return records, None


def attachment_source_path(path_text: str) -> Path | None:
    path = Path(path_text).expanduser()
    try:
        resolved = path.resolve(strict=True)
    except OSError:
        return None
    if not resolved.is_file():
        return None
    return resolved


def store_profile_avatar(source: Path) -> str:
    suffix = source.suffix if source.suffix and len(source.suffix) <= 12 else ".bin"
    avatar_id = str(uuid.uuid4())
    destination = profile_avatar_root() / f"{avatar_id}{suffix}"
    destination.parent.mkdir(parents=True, exist_ok=True)
    tmp_destination = destination.with_suffix(destination.suffix + ".tmp")
    shutil.copyfile(source, tmp_destination)
    tmp_destination.replace(destination)
    return f"profile-avatars/{destination.name}"


def attachment_mime_type(path: Path, override: str | None) -> str:
    if override is not None and override.strip():
        return override.strip()
    guessed, _encoding = mimetypes.guess_type(path.name)
    return guessed or "application/octet-stream"


def store_attachment_bytes(source: Path, attachment_id: str) -> tuple[str, str, int]:
    destination = attachment_root() / f"{attachment_id}.bin"
    destination.parent.mkdir(parents=True, exist_ok=True)
    digest = hashlib.sha256()
    size = 0
    tmp_destination = destination.with_suffix(".tmp")
    with source.open("rb") as src, tmp_destination.open("wb") as dst:
        while True:
            chunk = src.read(1024 * 1024)
            if not chunk:
                break
            size += len(chunk)
            if size > MAX_ATTACHMENT_BYTES:
                tmp_destination.unlink(missing_ok=True)
                raise ValueError("too_large")
            digest.update(chunk)
            dst.write(chunk)
    tmp_destination.replace(destination)
    return f"attachments/{attachment_id}.bin", digest.hexdigest(), size


