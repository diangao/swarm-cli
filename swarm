def command_attachment_upload(argv: list[str]) -> int:
    path_text = arg_value(argv, "--path")
    channel = arg_value(argv, "--channel")
    mime_override = arg_value(argv, "--mime-type")
    if path_text is None:
        return write_stderr("Error: --path is required\nCode: INVALID_ARG\n")
    if channel is None:
        return write_stderr("Error: --channel is required\nCode: INVALID_ARG\n")
    if not (channel.startswith("#") or channel.startswith("dm:@")):
        return write_stderr("Error: attachment channel must be a channel, thread, or DM\nCode: INVALID_TARGET\n")

    source = attachment_source_path(path_text)
    if source is None:
        return write_stderr(f"Error: File not found: {path_text}\nCode: NOT_FOUND\n")

    def action(state: dict[str, Any]) -> int:
        if not target_joined_for_write(state, channel):
            return write_stderr(f"Error: Not joined to target: {channel}\nCode: NOT_JOINED\n")
        if channel.startswith("#") and ":" not in channel:
            ensure_channel_catalog(state, channel)
        attachment_id = str(uuid.uuid4())
        try:
            stored_path, digest, size = store_attachment_bytes(source, attachment_id)
        except ValueError as exc:
            if str(exc) == "too_large":
                return write_stderr("Error: attachment exceeds 50MB limit\nCode: UPLOAD_FAILED\n")
            raise
        record = attachment_item(
            attachment_id,
            channel,
            source.name,
            attachment_mime_type(source, mime_override),
            size,
            digest,
            stored_path,
            current_timestamp(),
        )
        state.setdefault("attachments", []).append(record)
        return write_stdout(
            f"Attachment uploaded. Attachment ID: {attachment_id}\n"
            f"filename: {record['filename']}\n"
            f"mime_type: {record['mime_type']}\n"
            f"size_bytes: {record['size_bytes']}\n"
            f"sha256: {record['sha256']}\n"
            f"channel: {channel}\n"
        )

    return with_mutable_state(action)


def command_attachment_view(argv: list[str]) -> int:
    attachment_id = arg_value(argv, "--id")
    output_text = arg_value(argv, "--output")
    if attachment_id is None:
        return write_stderr("Error: --id is required\nCode: INVALID_ARG\n")
    if output_text is None:
        return write_stderr("Error: --output is required\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        record = attachment_by_id(state, attachment_id)
        if record is None:
            return write_stderr("Error: Attachment not found\nCode: NOT_FOUND\n")
        stored = state_dir() / record["stored_path"]
        if not stored.is_file():
            return write_stderr("Error: Attachment content missing\nCode: NOT_FOUND\n")
        output = Path(output_text).expanduser()
        output.parent.mkdir(parents=True, exist_ok=True)
        shutil.copyfile(stored, output)
        return write_stdout(f"Attachment {attachment_id} saved to {output}.\n")

    return with_read_state(action)


