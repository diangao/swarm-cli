def command_server_info() -> int:
    def action(state: dict[str, Any]) -> int:
        channels = sorted(state.get("channels", []), key=lambda row: row["name"])
        agents = [profile for profile in state.get("profiles", []) if profile["kind"] == "agent"]
        humans = [profile for profile in state.get("profiles", []) if profile["kind"] == "human"]
        channel_rows = "\n".join(format_channel_row(channel) for channel in channels) or "No channels."
        agent_rows = "\n".join(f"- @{profile['name']} ({profile['display_name']})" for profile in agents) or "No agents."
        human_rows = "\n".join(f"- @{profile['name']} ({profile['display_name']})" for profile in humans) or "No humans."
        return write_stdout(
            "## Server Info\n\n"
            "### Channels\n"
            f"{channel_rows}\n\n"
            "### Agents\n"
            f"{agent_rows}\n\n"
            "### Humans\n"
            f"{human_rows}\n"
        )

    return with_read_state(action)


