def load_state() -> dict[str, Any]:
    conn = connect_state()
    try:
        initialize_database(conn)
        return read_state(conn)
    finally:
        conn.close()


def save_state(state: dict[str, Any]) -> None:
    conn = connect_state()
    try:
        initialize_database(conn)
        with conn:
            replace_state(conn, state)
    finally:
        conn.close()


def with_read_state(action: Callable[[dict[str, Any]], int]) -> int:
    state = load_state()
    return action(state)


def with_mutable_state(action: Callable[[dict[str, Any]], int]) -> int:
    conn = connect_state()
    try:
        initialize_database(conn)
        conn.execute("BEGIN IMMEDIATE")
        state = read_state(conn)
        result = action(state)
        replace_state(conn, state)
        conn.commit()
        return result
    except Exception:
        conn.rollback()
        raise
    finally:
        conn.close()


def with_mutable_state_value(action: Callable[[dict[str, Any]], Any]) -> Any:
    conn = connect_state()
