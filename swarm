def reminder_due(record: dict[str, Any], now_text: str) -> bool:
    return record["status"] in {"scheduled", "snoozed"} and str(record["next_fire_at"]) <= now_text


def fire_due_reminders(state: dict[str, Any]) -> int:
    now = datetime.now()
    now_text = now.strftime("%Y-%m-%d %H:%M:%S")
    due = sorted(
        [record for record in state.get("reminders", []) if reminder_due(record, now_text)],
        key=lambda row: (str(row["next_fire_at"]), str(row["id"])),
    )
    fired = 0
    for reminder in due:
        detail_parts = [f"title={reminder['title']}"]
        target = reminder.get("target")
        record = None
        if target:
            body = f"Reminder {reminder['id']}: {reminder['title']}"
            record = append_message(state, target, body, sender_type="system", author="system")
            append_inbox_for_message(state, record)
            detail_parts.append(f"target={target}")
            detail_parts.append(f"message_id={record['id']}")
        wake_status = route_reminder_wake(state, reminder, record)
        if wake_status is not None:
            detail_parts.append(f"wake={wake_status}")
            append_daemon_event(
                state,
                "wake_route",
                {
                    "source": "reminder",
                    "reminder_id": reminder["id"],
                    "target": target,
                    "status": wake_status,
                },
            )
        append_reminder_event(state, reminder["id"], "fired", " ".join(detail_parts))
        fired += 1

        recurrence = reminder.get("recurrence")
        if recurrence:
            delta = parse_duration(str(recurrence))
            if delta is None or delta.total_seconds() <= 0:
                reminder["status"] = "failed"
                append_reminder_event(state, reminder["id"], "fire_failed", f"invalid recurrence={recurrence}")
            else:
                reminder["status"] = "scheduled"
                anchor = parse_state_datetime(str(reminder["next_fire_at"])) or now
                next_fire = anchor + delta
                while next_fire <= now:
                    next_fire += delta
                reminder["next_fire_at"] = next_fire.strftime("%Y-%m-%d %H:%M:%S")
                append_reminder_event(state, reminder["id"], "rescheduled", f"next={reminder['next_fire_at']}")
        else:
            reminder["status"] = "fired"
        reminder["updated_at"] = current_timestamp()
    return fired


def process_due_reminders_once() -> int:
    fired_count = 0

    def action(state: dict[str, Any]) -> int:
        nonlocal fired_count
        fired_count = fire_due_reminders(state)
        return 0

    with_mutable_state(action)
    return fired_count


def parse_positive_int_arg(argv: list[str], flag: str) -> tuple[int | None, str | None]:
    value = arg_value(argv, flag)
    if value is None:
        return None, None
    try:
        parsed = int(value)
    except ValueError:
        return None, f"{flag} must be a positive integer"
    if parsed < 1:
        return None, f"{flag} must be a positive integer"
    return parsed, None


def parse_poll_interval(argv: list[str]) -> tuple[float, str | None]:
    value = arg_value(argv, "--poll-interval") or "5s"
    delta = parse_duration(value)
    if delta is None or delta.total_seconds() <= 0:
        return 0.0, "--poll-interval must be a positive duration like 5s, 1m, 1h, or 1d"
    return delta.total_seconds(), None


def parse_duration_arg(argv: list[str], flag: str, default: str) -> tuple[float, str | None]:
    value = arg_value(argv, flag) or default
    delta = parse_duration(value)
    if delta is None or delta.total_seconds() <= 0:
        return 0.0, f"{flag} must be a positive duration like 5s, 1m, 1h, or 1d"
    return delta.total_seconds(), None


def parse_agent_name_arg(argv: list[str], flag: str = "--name") -> tuple[str | None, str | None]:
    if flag_missing_value(argv, flag):
        return None, f"{flag} requires a value"
    name = arg_value(argv, flag)
    if name is not None:
        name = name.removeprefix("@")
    if not name:
        return None, f"{flag} is required"
    return name, None


def daemon_record_event(event: str, detail: dict[str, Any] | str) -> int:
    def action(state: dict[str, Any]) -> int:
        append_daemon_event(state, event, detail)
        return 0

    return with_mutable_state(action)


def slack_socket_payload_from_frame(frame: dict[str, Any]) -> dict[str, Any] | None:
    if frame.get("type") == "events_api" and isinstance(frame.get("payload"), dict):
        return frame["payload"]
    if frame.get("type") in {"event", "slack_event"} and isinstance(frame.get("payload"), dict):
        return frame["payload"]
    if isinstance(frame.get("event"), dict):
        return frame
    return None


def read_mock_socket_frames(path_text: str) -> tuple[list[dict[str, Any]] | None, str | None]:
    path = Path(path_text).expanduser()
    try:
        raw = path.read_text()
    except OSError:
        return None, f"mock socket file not found: {path_text}"
    if not raw.strip():
        return None, "mock socket file is empty"
    try:
        decoded = json.loads(raw)
    except json.JSONDecodeError:
        frames: list[dict[str, Any]] = []
        for line_number, line in enumerate(raw.splitlines(), start=1):
            if not line.strip():
                continue
            try:
                frame = json.loads(line)
            except json.JSONDecodeError:
                return None, f"mock socket file line {line_number} is not valid JSON"
            if not isinstance(frame, dict):
                return None, f"mock socket file line {line_number} must be a JSON object"
            frames.append(frame)
        if not frames:
            return None, "mock socket file did not contain any frames"
        return frames, None
    if isinstance(decoded, dict):
        return [decoded], None
    if isinstance(decoded, list) and all(isinstance(item, dict) for item in decoded):
        return decoded, None
    return None, "mock socket file must be a JSON object, JSON array, or JSONL objects"


def daemon_ingest_slack_payload(workspace: str, payload: dict[str, Any]) -> tuple[str | None, str | None]:
    event, event_error = normalized_slack_event(payload)
    if event_error is not None:
        daemon_record_event("slack_socket_skip", {"workspace": workspace, "reason": event_error})
        return "skipped", None
    assert event is not None
    if event["workspace"] != workspace:
        daemon_record_event(
            "slack_socket_skip",
            {
                "workspace": workspace,
                "event_workspace": event["workspace"],
                "reason": "workspace mismatch",
            },
        )
        return "skipped", None

    result: dict[str, Any] = {}

    def action(state: dict[str, Any]) -> int:
        mapping, record, status, error_code, error = ingest_normalized_slack_event(state, event)
        if error is not None:
            append_daemon_event(
                state,
                "slack_socket_error",
                {
                    "workspace": workspace,
                    "channel_id": event["channel_id"],
                    "slack_ts": event["slack_ts"],
                    "code": error_code,
                    "error": error,
                },
            )
            result["error"] = error
            result["code"] = error_code
            return 0
        assert mapping is not None and record is not None and status is not None
        append_daemon_event(
            state,
            "slack_socket_ingest",
            {
                "workspace": workspace,
                "channel_id": event["channel_id"],
                "slack_ts": event["slack_ts"],
                "message_id": record["id"],
                "status": status,
                "target": mapping["target"],
            },
        )
        if status == "imported":
            routed = route_message_wakes(state, record)
            if routed:
                append_daemon_event(
                    state,
                    "wake_route",
                    {
                        "source": "slack",
                        "message_id": record["id"],
                        "routes": routed,
                    },
                )
        result["status"] = status
        result["message_id"] = record["id"]
        return 0

    with_mutable_state(action)
    if "error" in result:
        return None, str(result["error"])
    return str(result.get("status", "skipped")), None


def slack_socket_url(app_token: str, timeout_seconds: float) -> tuple[str | None, str | None]:
    response, error = slack_web_api_call(app_token, "apps.connections.open", {}, timeout_seconds)
    if error is not None:
        return None, error
    assert response is not None
    url = response.get("url")
    if not isinstance(url, str) or not url.startswith("wss://"):
        return None, "Slack Socket Mode response did not include a websocket URL"
    return url, None


def run_mock_slack_socket(workspace: str, frames: list[dict[str, Any]], max_events: int | None) -> int:
    daemon_record_event("slack_socket_connect", {"workspace": workspace, "source": "mock"})
    processed = 0
    for frame in frames:
        frame_type = frame.get("type")
        if frame_type == "disconnect":
            daemon_record_event("slack_socket_disconnect", {"workspace": workspace, "source": "mock", "reason": frame.get("reason") or "mock"})
            daemon_record_event("slack_socket_reconnect", {"workspace": workspace, "source": "mock"})
            continue
        payload = slack_socket_payload_from_frame(frame)
        if payload is None:
            daemon_record_event("slack_socket_skip", {"workspace": workspace, "source": "mock", "reason": "unsupported frame"})
            continue
        status, error = daemon_ingest_slack_payload(workspace, payload)
        if error is not None:
            return write_stderr(f"Error: {error}\nCode: SLACK_SOCKET_INGEST_FAILED\n")
        if status != "skipped":
            processed += 1
        if max_events is not None and processed >= max_events:
            break
    return write_stdout(f"Slack daemon processed {processed} event frame(s).\n")


def run_real_slack_socket(
    workspace: str,
    app_token: str,
    max_events: int | None,
    socket_timeout_seconds: float,
    reconnect_backoff_seconds: float,
) -> int:
    processed = 0
    while True:
        url, url_error = slack_socket_url(app_token, socket_timeout_seconds)
        if url_error is not None:
            daemon_record_event("slack_socket_error", {"workspace": workspace, "error": url_error})
            return write_stderr(f"Error: {url_error}\nCode: SLACK_SOCKET_CONNECT_FAILED\n")
        try:
            import websocket  # type: ignore[import-not-found]

            ws = websocket.create_connection(url, timeout=socket_timeout_seconds)
            daemon_record_event("slack_socket_connect", {"workspace": workspace, "source": "socket_mode"})
            write_stdout(f"Slack Socket Mode connected for workspace {workspace}.\n")
            try:
                while True:
                    raw = ws.recv()
                    if not isinstance(raw, str):
                        continue
                    try:
                        frame = json.loads(raw)
                    except json.JSONDecodeError:
                        daemon_record_event("slack_socket_skip", {"workspace": workspace, "reason": "invalid websocket JSON"})
                        continue
                    if not isinstance(frame, dict):
                        daemon_record_event("slack_socket_skip", {"workspace": workspace, "reason": "non-object websocket frame"})
                        continue
                    envelope_id = frame.get("envelope_id")
                    if isinstance(envelope_id, str) and envelope_id:
                        ws.send(json.dumps({"envelope_id": envelope_id}, separators=(",", ":")))
                    if frame.get("type") == "disconnect":
                        daemon_record_event("slack_socket_disconnect", {"workspace": workspace, "source": "socket_mode", "reason": frame.get("reason") or "disconnect"})
                        break
                    payload = slack_socket_payload_from_frame(frame)
                    if payload is None:
                        continue
                    status, error = daemon_ingest_slack_payload(workspace, payload)
                    if error is not None:
                        return write_stderr(f"Error: {error}\nCode: SLACK_SOCKET_INGEST_FAILED\n")
                    if status != "skipped":
                        processed += 1
                    if max_events is not None and processed >= max_events:
                        ws.close()
                        return write_stdout(f"Slack daemon processed {processed} event frame(s).\n")
            finally:
                try:
                    ws.close()
                except Exception:
                    pass
        except KeyboardInterrupt:
            return write_stdout(f"Slack daemon stopped after {processed} event frame(s).\n")
        except Exception as exc:
            daemon_record_event("slack_socket_disconnect", {"workspace": workspace, "source": "socket_mode", "reason": type(exc).__name__})
        daemon_record_event("slack_socket_reconnect", {"workspace": workspace, "source": "socket_mode", "backoff_seconds": reconnect_backoff_seconds})
        time.sleep(reconnect_backoff_seconds)


def command_daemon_slack(argv: list[str]) -> int:
    unknown = unknown_flags(
        argv,
        {"--workspace", "--mock-socket-file", "--max-events", "--socket-timeout", "--reconnect-backoff"},
    )
    if unknown:
        return write_stderr(f"Error: unknown daemon slack flag: {unknown[0]}\nCode: INVALID_ARG\n")
    if (
        flag_missing_value(argv, "--workspace")
        or flag_missing_value(argv, "--mock-socket-file")
        or flag_missing_value(argv, "--max-events")
        or flag_missing_value(argv, "--socket-timeout")
        or flag_missing_value(argv, "--reconnect-backoff")
    ):
        return write_stderr("Error: daemon slack flags require values\nCode: INVALID_ARG\n")
    workspace = arg_value(argv, "--workspace")
    if not workspace:
        return write_stderr("Error: --workspace is required\nCode: INVALID_ARG\n")
    max_events, max_error = parse_positive_int_arg(argv, "--max-events")
    if max_error is not None:
        return write_stderr(f"Error: {max_error}\nCode: INVALID_ARG\n")
    socket_timeout_seconds, timeout_error = parse_duration_arg(argv, "--socket-timeout", "30s")
    if timeout_error is not None:
        return write_stderr(f"Error: {timeout_error}\nCode: INVALID_ARG\n")
    reconnect_backoff_seconds, backoff_error = parse_duration_arg(argv, "--reconnect-backoff", "1s")
    if backoff_error is not None:
        return write_stderr(f"Error: {backoff_error}\nCode: INVALID_ARG\n")

    state = load_state()
    config = slack_workspace_by_id(state, workspace)
    if config is None:
        return write_stderr(
            "Error: Slack workspace config not found\n"
            "Code: NOT_FOUND\n"
            "Next action: configure it with swarm slack configure.\n"
        )
    if config.get("mode") != "socket_mode":
        return write_stderr("Error: Slack daemon requires workspace mode socket_mode\nCode: INVALID_ARG\n")
    app_token_env = config.get("app_token_env")
    if not isinstance(app_token_env, str) or not app_token_env:
        return write_stderr("Error: Slack Socket Mode app token env is not configured\nCode: SLACK_TOKEN_MISSING\n")
    app_token = os.environ.get(app_token_env)
    if not app_token:
        return write_stderr(f"Error: Slack Socket Mode app token missing in env var {app_token_env}\nCode: SLACK_TOKEN_MISSING\n")

    mock_socket_file = arg_value(argv, "--mock-socket-file")
    if mock_socket_file is not None:
        frames, frame_error = read_mock_socket_frames(mock_socket_file)
        if frame_error is not None:
            return write_stderr(f"Error: {frame_error}\nCode: INVALID_ARG\n")
        assert frames is not None
        return run_mock_slack_socket(workspace, frames, max_events)

    return run_real_slack_socket(
        workspace,
        app_token,
        max_events,
        socket_timeout_seconds,
        reconnect_backoff_seconds,
    )


def command_daemon_run(argv: list[str]) -> int:
    unknown = unknown_flags(argv, {"--poll-interval", "--max-iterations", "--once"})
    if unknown:
        return write_stderr(f"Error: unknown daemon run flag: {unknown[0]}\nCode: INVALID_ARG\n")
    if flag_missing_value(argv, "--poll-interval") or flag_missing_value(argv, "--max-iterations"):
        return write_stderr("Error: daemon run flags require values\nCode: INVALID_ARG\n")
    interval_seconds, interval_error = parse_poll_interval(argv)
    if interval_error is not None:
        return write_stderr(f"Error: {interval_error}\nCode: INVALID_ARG\n")
    max_iterations, max_error = parse_positive_int_arg(argv, "--max-iterations")
    if max_error is not None:
        return write_stderr(f"Error: {max_error}\nCode: INVALID_ARG\n")
    if "--once" in argv:
        max_iterations = 1

    iterations = 0
    total_fired = 0
    try:
        while True:
            total_fired += process_due_reminders_once()
            iterations += 1
            if max_iterations is not None and iterations >= max_iterations:
                return write_stdout(
                    f"Daemon processed {total_fired} reminder(s) in {iterations} iteration(s).\n"
                )
            time.sleep(interval_seconds)
    except KeyboardInterrupt:
        return write_stdout(
            f"Daemon stopped. Processed {total_fired} reminder(s) in {iterations} iteration(s).\n"
        )


def format_daemon_wake_row(record: dict[str, Any]) -> str:
    running = "running" if record.get("running") else "idle"
    active = "-"
    if record.get("active_reason") or record.get("active_message_id"):
        active = (
            f"{record.get('active_reason') or '-'}"
            f"/{short_id(str(record['active_message_id'])) if record.get('active_message_id') else '-'}"
        )
    pending = "-"
    if int(record.get("pending_count", 0)) > 0:
        pending = (
            f"{record['pending_count']} "
            f"{record.get('pending_reason') or '-'}"
            f"/{short_id(str(record['pending_message_id'])) if record.get('pending_message_id') else '-'}"
        )
    return (
        f"@{record['agent_name']} {running} active_turns={record['active_wake_count']} "
        f"active={active} pending={pending} updated={record['updated_at']}"
    )


