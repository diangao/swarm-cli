        "scrub_gate": {
            "credentials": 0,
            "other_people_dm_originals": 0,
            "owner_sensitive": 0,
        },
        "excluded_counts": {
            "dm_originals": counters.get("excluded_dm_originals", 0),
            "owner_sensitive": counters.get("excluded_owner_sensitive", 0),
        },
    }
    seed_path.write_text(json.dumps(seed_payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    config_payload: dict[str, Any] = {
        "batch_size": batch_size,
        "max_runtime_seconds": max_runtime_seconds,
        "report_target": report_target,
