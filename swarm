def command_agent_worker(argv: list[str]) -> int:
    unknown = unknown_flags(argv, {"--name", "--once", "--interval", "--session-id", "--require-seed"})
    if unknown:
        return write_stderr(f"Error: unknown agent worker flag: {unknown[0]}\nCode: INVALID_ARG\n")
    name, name_error = parse_agent_name_arg(argv)
    if name_error is not None:
        return write_stderr(f"Error: {name_error}\nCode: INVALID_ARG\n")
    assert name is not None
    if flag_missing_value(argv, "--interval") or flag_missing_value(argv, "--session-id"):
        return write_stderr("Error: Agent worker flags require values\nCode: INVALID_ARG\n")
    interval = parse_duration(arg_value(argv, "--interval") or "5s")
    if interval is None or interval.total_seconds() <= 0:
        return write_stderr("Error: --interval must be a positive duration like 5s, 1m, 1h, or 1d\nCode: INVALID_ARG\n")
    session_id = arg_value(argv, "--session-id") or f"worker-{name}-{uuid.uuid4().hex[:8]}"
    require_seed = "--require-seed" in argv
    once = "--once" in argv
    if not once:
        return write_stderr(
            "Error: the agent worker loop is retired; run the resident daemon instead (swarm daemon resident)\n"
            "Code: WORKER_RETIRED\n"
        )
    pid = str(os.getpid())
    iterations = 0

    def tick(status: str, detail: str) -> int:
        def action(state: dict[str, Any]) -> int:
            agent = agent_by_name(state, name)
            if agent is None:
                return write_stderr("Error: Agent not found\nCode: NOT_FOUND\n")
            workspace = state_dir() / str(agent["workspace_path"])
            if require_seed and not (workspace / "seed.json").exists():
                return write_stderr(f"Error: seed workspace missing for @{name}: {workspace}\nCode: NOT_FOUND\n")
            error = record_agent_heartbeat(state, name, status, pid, session_id, detail)
            if error is not None:
                return write_stderr(f"Error: {error}\nCode: NOT_FOUND\n")
            return 0

        return with_mutable_state(action)

    while True:
        result = tick("alive", "worker loop heartbeat")
        if result != 0:
            return result
        iterations += 1
        if once:
            return write_stdout(f"Worker heartbeat recorded for @{name}. Session: {session_id}. Iterations: {iterations}.\n")
        try:
            time.sleep(interval.total_seconds())
        except KeyboardInterrupt:
            tick("stopped", "worker loop stopped")
            return write_stdout(f"Worker stopped for @{name}. Session: {session_id}. Iterations: {iterations}.\n")


def command_agent_collab_smoke(argv: list[str]) -> int:
    unknown = unknown_flags(argv, {"--channel", "--task-author", "--worker", "--verifier", "--title"})
    if unknown:
        return write_stderr(f"Error: unknown agent collab-smoke flag: {unknown[0]}\nCode: INVALID_ARG\n")
    if (
        flag_missing_value(argv, "--channel")
        or flag_missing_value(argv, "--task-author")
        or flag_missing_value(argv, "--worker")
        or flag_missing_value(argv, "--verifier")
        or flag_missing_value(argv, "--title")
    ):
        return write_stderr("Error: Agent collab-smoke flags require values\nCode: INVALID_ARG\n")
    channel = arg_value(argv, "--channel")
    if channel is None or not channel.startswith("#") or ":" in channel:
        return write_stderr("Error: --channel must be a top-level channel\nCode: INVALID_ARG\n")
    task_author = (arg_value(argv, "--task-author") or "").removeprefix("@")
    worker = (arg_value(argv, "--worker") or "").removeprefix("@")
    verifier = (arg_value(argv, "--verifier") or "").removeprefix("@")
    title = arg_value(argv, "--title") or "Swarm collab smoke"
    if not task_author or not worker or not verifier:
        return write_stderr("Error: --task-author, --worker, and --verifier are required\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        missing = [name for name in (task_author, worker, verifier) if agent_by_name(state, name) is None]
        if missing:
            return write_stderr(f"Error: Agent not found: @{missing[0]}\nCode: NOT_FOUND\n")
        ensure_channel_catalog(state, channel)
        task = append_task_for_author(state, channel, title, task_author)
        task["assignee"] = worker
        task["status"] = "in_progress"
        task["updated_at"] = current_timestamp()
        thread = reply_thread_target(channel, str(task["message_id"]))
        report = append_message(
            state,
            thread,
            f"Work completed for task #{task['number']}: claim accepted, artifact produced, ready for verification.",
            author=worker,
        )
        verify = append_message(
            state,
            thread,
            f"Verified task #{task['number']}: worker report present and task state coherent.",
            author=verifier,
        )
        task["status"] = "in_review"
        task["updated_at"] = current_timestamp()
        for name in (task_author, worker, verifier):
            record_agent_heartbeat(
                state,
                name,
                "alive",
                None,
                f"collab-smoke-{short_id(str(task['message_id']))}",
                f"collab-smoke role={name}",
            )
        result = {
            "channel": channel,
            "task_number": task["number"],
            "task_message_id": task["message_id"],
            "thread": thread,
            "task_author": task_author,
            "worker": worker,
            "verifier": verifier,
            "worker_report_id": report["id"],
            "verifier_report_id": verify["id"],
            "status": task["status"],
        }
        return write_stdout(
            "## Agent Collab Smoke\n\n"
            f"{json.dumps(result, sort_keys=True, separators=(',', ':'))}\n"
        )

    return with_mutable_state(action)


def write_agent_seed_workspace(agent: dict[str, Any], destination: Path) -> None:
    destination.mkdir(parents=True, exist_ok=True)
    for child in ("runtime", "logs", "artifacts"):
        (destination / child).mkdir(exist_ok=True)
