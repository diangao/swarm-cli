def command_channel_members(argv: list[str]) -> int:
    target = arg_value(argv, "--target")
    if target is None and argv:
        target = argv[0]
    if target is None:
        return write_stderr("Error: channel target is required\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        channel = channel_record(state, target)
        if channel is None and not target.startswith("dm:@"):
            return write_stderr("Error: Channel not found\nCode: NOT_FOUND\n")
        members = members_for_target(state, target)
        agents = [member for member in members if member["kind"] == "agent"]
        humans = [member for member in members if member["kind"] == "human"]
        agent_rows = "\n".join(f"  - {member_display(member)}" for member in agents) or "  - none"
        human_rows = "\n".join(f"  - {member_display(member)}" for member in humans) or "  - none"
        if target.startswith("dm:@"):
            channel_label = target
        else:
            channel_label = channel_for_target(target)
            if channel and channel.get("private"):
                channel_label += " (private)"
        return write_stdout(
            "## Channel Members\n\n"
            f"Channel: {channel_label}\n"
            "Members means join/post authority for this surface.\n\n"
            "### Agents\n"
            f"{agent_rows}\n\n"
            "### Humans\n"
            "Role labels show server-level owner/admin authority; no role label means ordinary member.\n"
            f"{human_rows}\n"
        )

    return with_read_state(action)


def command_channel_join(argv: list[str]) -> int:
    target = arg_value(argv, "--target")
    if target is None and argv:
        target = argv[0]
    if target is None:
        return write_stderr("Error: channel target is required\nCode: INVALID_ARG\n")
    if not target.startswith("#") or ":" in target:
        return write_stderr("Error: join target must be a top-level channel\nCode: INVALID_TARGET\n")

    def action(state: dict[str, Any]) -> int:
        record = top_level_channel_record(state, target)
        if record is None:
            state.setdefault("channels", []).append(channel_item(target, False, True, "Local channel"))
        else:
            record["joined"] = True
        ensure_candidate_member(state, target)
        return write_stdout(f"Joined {target}.\n")

    return with_mutable_state(action)


def command_channel_leave(argv: list[str]) -> int:
    target = arg_value(argv, "--target")
    if target is None and argv:
        target = argv[0]
    if target is None:
        return write_stderr("Error: channel target is required\nCode: INVALID_ARG\n")
    if not target.startswith("#") or ":" in target:
        return write_stderr("Error: leave target must be a top-level channel\nCode: INVALID_TARGET\n")

    def action(state: dict[str, Any]) -> int:
        record = top_level_channel_record(state, target)
        if record is None:
            return write_stderr("Error: Channel not found\nCode: NOT_FOUND\n")
        if record.get("private"):
            return write_stderr("Error: private channel membership is managed by the server\nCode: LEAVE_FAILED\n")
        record["joined"] = False
        remove_candidate_member(state, target)
        return write_stdout(f"Left {target}.\n")

    return with_mutable_state(action)


