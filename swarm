    ):
        return write_stderr("Error: daemon dispatch claim flags require values\nCode: INVALID_ARG\n")
    owner = arg_value(argv, "--owner")
    if not owner or not owner.strip():
        return write_stderr("Error: --owner is required\nCode: INVALID_ARG\n")
    lease_seconds = 300
    lease_text = arg_value(argv, "--lease-seconds")
    if lease_text is not None:
        try:
            lease_seconds = int(lease_text)
        except ValueError:
            lease_seconds = 0
        if lease_seconds <= 0:
            return write_stderr("Error: --lease-seconds must be a positive integer\nCode: INVALID_ARG\n")
    limit = 1
    limit_text = arg_value(argv, "--limit")
    if limit_text is not None:
        try:
            limit = int(limit_text)
        except ValueError:
            limit = 0
        if limit <= 0:
            return write_stderr("Error: --limit must be a positive integer\nCode: INVALID_ARG\n")
    owner_name = owner.strip()

    def action(state: dict[str, Any]) -> int:
        now = datetime.strptime(current_timestamp(), "%Y-%m-%d %H:%M:%S")
        lines: list[str] = []
        claimed = 0
        for item in state.setdefault("daemon_dispatches", []):
            if claimed >= limit:
                break
            if not dispatch_lease_available(item, now):
                continue
            reclaimed = item["status"] == "leased"
            if item["attempts"] >= item["max_attempts"]:
                item["status"] = "failed"
                item["lease_owner"] = None
                item["lease_expires_at"] = None
                item["error"] = "max attempts exceeded"
                append_daemon_event(state, "dispatch_failed", {"id": item["id"], "reason": "max attempts exceeded"})
                lines.append(f"- {item['id']} @{item['agent']} failed (max attempts exceeded)")
                continue
            item["status"] = "leased"
            item["attempts"] += 1
            item["lease_owner"] = owner_name
            expires = now + timedelta(seconds=lease_seconds)
            item["lease_expires_at"] = expires.strftime("%Y-%m-%d %H:%M:%S")
            event = "dispatch_reclaimed" if reclaimed else "dispatch_leased"
            append_daemon_event(state, event, {"id": item["id"], "owner": owner_name, "attempts": item["attempts"]})
            lines.append(
                f"- {item['id']} @{item['agent']} kind={item['kind']} attempts={item['attempts']} "
                f"lease_expires={item['lease_expires_at']}{' (reclaimed)' if reclaimed else ''}"
            )
            claimed += 1
        header = f"## Dispatch Claim ({claimed} leased by {owner_name})\n"
        body = "\n".join(lines) if lines else "No claimable dispatches."
        return write_stdout(header + "\n" + body + "\n")

    return with_mutable_state(action)


def find_dispatch(state: dict[str, Any], dispatch_id: int) -> dict[str, Any] | None:
    for item in state.get("daemon_dispatches", []):
        if item["id"] == dispatch_id:
            return item
    return None


def dispatch_holder_check(item: dict[str, Any], owner_name: str) -> str | None:
    if item["status"] != "leased":
        return f"Error: Dispatch {item['id']} is not leased (status: {item['status']})\nCode: DISPATCH_NOT_HELD\n"
    if item["lease_owner"] != owner_name:
        return f"Error: Dispatch {item['id']} lease is held by another owner\nCode: DISPATCH_NOT_HELD\n"
    now = datetime.strptime(current_timestamp(), "%Y-%m-%d %H:%M:%S")
    expires = parse_state_timestamp(item.get("lease_expires_at"))
    if expires is None or expires <= now:
        return f"Error: Dispatch {item['id']} lease has expired\nCode: DISPATCH_NOT_HELD\n"
    return None


def credential_shape_re() -> re.Pattern[str]:
    token_kinds = ("agent", "machine", "proj", "live", "test")
    token_prefix = "sk" + "_(?:" + "|".join(token_kinds) + ")" + "_"
    app_prefix = "xapp" + "-"
    anthropic_prefix = "sk" + "-ant-"
    openai_project_prefix = "sk" + "-proj-"
    openai_prefix = "sk" + "-"
    aws_prefix = "AK" + "IA"
    pem_header = "-----BEGIN" + " [A-Z0-9 ]*PRIVATE KEY-----"
    return re.compile(
        r"(?:" + token_prefix + r"[A-Za-z0-9_-]{4,}|xox[baprs]-[A-Za-z0-9-]{8,}|"
        + app_prefix + r"[A-Za-z0-9-]{8,}|Bearer [A-Za-z0-9._-]{20,}|"
        + anthropic_prefix + r"[A-Za-z0-9_-]{8,}|"
        + openai_project_prefix + r"[A-Za-z0-9_-]{8,}|"
        + openai_prefix + r"[A-Za-z0-9]{20,}|"
        + aws_prefix + r"[0-9A-Z]{16}|"
        + pem_header + r")"
    )


CREDENTIAL_SHAPE_RE = credential_shape_re()
BLOCKED_TURN_OUTPUT = "[blocked credential-shaped output]"


def contains_credential_shape(*values: str | None) -> bool:
    return any(value is not None and CREDENTIAL_SHAPE_RE.search(value) for value in values)


def clipped_turn_output(value: str | None, limit: int = 12000) -> str | None:
    if value is None:
        return None
    if len(value) <= limit:
        return value
    return value[:limit] + f"\n[truncated {len(value) - limit} chars]"


def safe_turn_env(agent_name: str, turn_id: int, session_id: str, workspace: Path, dispatch_id: int | None, home: Path | None = None) -> dict[str, str]:
    env: dict[str, str] = {}
    for key in ("LANG", "LC_ALL", "TERM", "USER", "LOGNAME"):
        value = os.environ.get(key)
        if value and not contains_credential_shape(value):
            env[key] = value
    cli_dir = str(Path(__file__).resolve().parent)
    path_value = os.environ.get("PATH") or ""
    if contains_credential_shape(path_value):
        env["PATH"] = cli_dir
    else:
        env["PATH"] = cli_dir + (os.pathsep + path_value if path_value else "")
    env["HOME"] = str(home if home is not None else workspace)
    env["SWARM_CANDIDATE_STATE_DIR"] = str(state_dir())
    env["SWARM_AGENT_NAME"] = agent_name
    env["SWARM_TURN_ID"] = str(turn_id)
    env["SWARM_SESSION_ID"] = session_id
    if dispatch_id is not None:
        env["SWARM_DISPATCH_ID"] = str(dispatch_id)
    return env


def dispatch_payload_fields(payload: str) -> dict[str, str]:
    try:
        decoded = json.loads(payload)
    except json.JSONDecodeError:
        return {"input_text": payload}
    if not isinstance(decoded, dict):
        return {"input_text": payload}
    fields: dict[str, str] = {}
    for source_key, dest_key in (
        ("target", "target"),
        ("input", "input_text"),
        ("text", "input_text"),
        ("body", "input_text"),
        ("message", "input_text"),
        ("session_id", "session_id"),
        ("input_message_id", "input_message_id"),
    ):
        value = decoded.get(source_key)
        if isinstance(value, str):
            fields[dest_key] = value
    return fields


def finish_dispatch_after_turn(
    state: dict[str, Any],
    item: dict[str, Any],
    owner_name: str,
    success: bool,
    error_text: str | None,
) -> str | None:
    holder_error = dispatch_holder_check(item, owner_name)
    if holder_error is not None:
        return holder_error
    item["lease_owner"] = None
    item["lease_expires_at"] = None
    if success:
        item["status"] = "done"
        item["completed_time"] = current_timestamp()
        item["error"] = None
        append_daemon_event(state, "dispatch_completed", {"id": item["id"], "owner": owner_name, "source": "turn"})
        return None
    item["error"] = error_text or "turn failed"
    if item["attempts"] >= item["max_attempts"]:
        item["status"] = "failed"
        append_daemon_event(state, "dispatch_failed", {"id": item["id"], "reason": item["error"], "source": "turn"})
    else:
        item["status"] = "pending"
        append_daemon_event(state, "dispatch_requeued", {"id": item["id"], "reason": item["error"], "source": "turn"})
    return None


def prepare_daemon_turn(
    agent_arg: str,
    dispatch_id: int | None,
    owner_name: str | None,
    explicit_input: str | None,
    explicit_target: str | None,
    explicit_session_id: str | None,
    timeout_seconds: float,
) -> dict[str, Any]:
    def action(state: dict[str, Any]) -> dict[str, Any]:
        agent_name = agent_arg.removeprefix("@")
        dispatch_item = None
        payload_fields: dict[str, str] = {}
        if dispatch_id is not None:
            if not owner_name:
                return {"error": "--owner is required with --dispatch-id", "code": "INVALID_ARG"}
            dispatch_item = find_dispatch(state, dispatch_id)
            if dispatch_item is None:
                return {"error": f"Dispatch not found: {dispatch_id}", "code": "NOT_FOUND"}
            holder_error = dispatch_holder_check(dispatch_item, owner_name)
            if holder_error is not None:
                return {"raw_error": holder_error}
            if dispatch_item["agent"] != agent_name:
                return {"error": "Dispatch agent does not match --agent", "code": "INVALID_ARG"}
            payload_fields = dispatch_payload_fields(dispatch_item.get("payload") or "")
        agent = agent_by_name(state, agent_name)
        if agent is None:
            return {"error": "Agent not found", "code": "NOT_FOUND"}
        workspace_path = str(agent.get("workspace_path") or "")
        if not valid_workspace_path(workspace_path):
            return {"error": "Agent workspace path is invalid", "code": "INVALID_ARG"}
        runtime = str(agent.get("runtime") or "").strip()
        if not runtime:
            return {"error": "Agent runtime is empty", "code": "INVALID_ARG"}
        try:
            command = shlex.split(runtime)
        except ValueError as exc:
            return {"error": f"Agent runtime is not shell-parseable: {exc}", "code": "INVALID_ARG"}
        if not command:
            return {"error": "Agent runtime is empty", "code": "INVALID_ARG"}

        wake = daemon_wake_by_agent(state, agent_name)
        input_message_id = payload_fields.get("input_message_id")
        input_text = explicit_input if explicit_input is not None else payload_fields.get("input_text", "")
        target = explicit_target if explicit_target is not None else payload_fields.get("target")
        if not input_text and wake is not None and wake.get("active_message_id"):
            active_record, active_error = message_by_id(state, str(wake["active_message_id"]))
            if active_error is None and active_record is not None:
                input_text = str(active_record.get("body", ""))
                input_message_id = str(active_record["id"])
                if target is None:
                    target = str(active_record["target"])
                if wake.get("active_reason") == "attention":
                    input_text = (
                        "[attention wake] New channel message below. You were not mentioned. "
                        "Reply ONLY if you are addressed implicitly or have something genuinely useful to add; "
                        "otherwise output exactly SILENT and nothing else.\n\n" + input_text
                    )
        session_id = explicit_session_id or payload_fields.get("session_id")
        prior_done_sessions = [
            str(item["session_id"])
            for item in state.get("daemon_turns", [])
            if item["agent"] == agent_name and item["status"] == "done" and item.get("session_id")
        ]
        if not session_id:
            session_id = prior_done_sessions[-1] if prior_done_sessions else str(uuid.uuid4())
        resumable = session_id in prior_done_sessions
        runtime_kind = Path(command[0]).name
        if runtime_kind == "claude":
            # Real claude CLI: --resume only accepts an existing session; first
            # turns must create the session via --session-id (print mode).
            if resumable:
                command = [*command, "-p", "--resume", session_id]
            else:
                command = [*command, "-p", "--session-id", session_id]
        else:
            command = [*command, "--resume", session_id]
        now = current_timestamp()
        deadline = (datetime.strptime(now, "%Y-%m-%d %H:%M:%S") + timedelta(seconds=timeout_seconds)).strftime("%Y-%m-%d %H:%M:%S")
        turns = state.setdefault("daemon_turns", [])
        turn_id = max((int(item["id"]) for item in turns), default=0) + 1
        turns.append(
            daemon_turn_item(
                turn_id,
                now,
                now,
                agent_name,
                dispatch_id,
                "running",
                session_id,
                workspace_path,
                json.dumps(command, separators=(",", ":")),
                target,
                input_message_id,
                input_text,
                now,
                deadline,
                None,
                None,
                None,
                None,
                None,
            )
        )
        append_daemon_event(
            state,
            "turn_started",
            {"id": turn_id, "agent": agent_name, "dispatch_id": dispatch_id, "session_id": session_id},
        )
        return {
            "turn_id": turn_id,
            "agent": agent_name,
            "dispatch_id": dispatch_id,
            "owner": owner_name,
            "workspace_path": workspace_path,
            "workspace_abs": str(state_dir() / workspace_path),
            "command": command,
            "target": target,
            "input_message_id": input_message_id,
            "input_text": input_text,
            "session_id": session_id,
        }

    return with_mutable_state_value(action)


def finalize_daemon_turn(
    turn_id: int,
    agent_name: str,
    dispatch_id: int | None,
    owner_name: str | None,
    target: str | None,
    status: str,
    exit_code: int | None,
    stdout_text: str | None,
    stderr_text: str | None,
    error_text: str | None,
) -> dict[str, Any]:
    def action(state: dict[str, Any]) -> dict[str, Any]:
        turn = next((item for item in state.get("daemon_turns", []) if int(item["id"]) == turn_id), None)
        if turn is None:
            return {"error": f"Turn not found: {turn_id}", "code": "NOT_FOUND"}
        now = current_timestamp()
        dispatch_error = None
        if dispatch_id is not None:
            dispatch_item = find_dispatch(state, dispatch_id)
            if dispatch_item is None:
                dispatch_error = f"Dispatch not found during turn finalize: {dispatch_id}"
            elif owner_name is None:
                dispatch_error = "Missing dispatch owner during turn finalize"
            else:
                dispatch_error = finish_dispatch_after_turn(
                    state,
                    dispatch_item,
                    owner_name,
                    status == "done",
                    error_text,
                )
        wake_status = None
        wake = daemon_wake_by_agent(state, agent_name)
        if wake is not None and wake.get("running"):
            wake_status, _ = finish_daemon_wake(state, agent_name)
        effective_status = "failed" if dispatch_error is not None else status
        effective_error = "dispatch finalize failed" if dispatch_error is not None else error_text
        effective_exit_code = 1 if dispatch_error is not None and (exit_code is None or exit_code == 0) else exit_code
        turn["status"] = effective_status
        turn["updated_at"] = now
        turn["finished_at"] = now
        turn["exit_code"] = effective_exit_code
        turn["stdout_text"] = stdout_text
        turn["stderr_text"] = stderr_text
        turn["error"] = effective_error
        message_id = None
        stdout_clean = (stdout_text or "").strip()
        if stdout_clean == "SILENT":
            append_daemon_event(state, "turn_silent", {"id": turn_id, "agent": agent_name})
        elif dispatch_error is None and status == "done" and target and stdout_clean:
            record = append_message(state, target, stdout_clean, author=agent_name)
            message_id = record["id"]
        event_name = "turn_completed" if effective_status == "done" else "turn_failed"
        append_daemon_event(
            state,
            event_name,
            {
                "id": turn_id,
                "agent": agent_name,
                "dispatch_id": dispatch_id,
                "status": effective_status,
                "wake_status": wake_status,
                "message_id": message_id,
                "dispatch_error": dispatch_error,
            },
        )
        if dispatch_error is not None:
            return {"raw_error": dispatch_error}
        return {"wake_status": wake_status, "message_id": message_id}

    return with_mutable_state_value(action)


def format_daemon_turn_row(item: dict[str, Any]) -> str:
    dispatch = f" dispatch={item['dispatch_id']}" if item.get("dispatch_id") is not None else ""
    target = f" target={item['target']}" if item.get("target") else ""
    code = f" exit={item['exit_code']}" if item.get("exit_code") is not None else ""
    error = f" error={item['error']}" if item.get("error") else ""
    return (
        f"- {item['id']} @{item['agent']} status={item['status']}{dispatch}{target}"
        f" session={item['session_id']}{code}{error} updated={item['updated_at']}"
    )


def execute_daemon_turn(
    agent: str,
    dispatch_id: int | None,
    owner: str | None,
    input_text: str | None,
    target: str | None,
    session_id: str | None,
    timeout_seconds: float,
) -> dict[str, Any]:
    prepared = prepare_daemon_turn(
        agent,
        dispatch_id,
        owner.strip() if owner is not None else None,
        input_text,
        target,
        session_id,
        timeout_seconds,
    )
    if prepared.get("raw_error"):
        return {"ok": False, "raw_error": str(prepared["raw_error"])}
    if prepared.get("error"):
        return {"ok": False, "error": str(prepared["error"]), "code": str(prepared.get("code", "TURN_PREPARE_FAILED"))}

    workspace = Path(str(prepared["workspace_abs"]))
    workspace.mkdir(parents=True, exist_ok=True)
    command_list = prepared.get("command") or []
    runtime_kind = Path(str(command_list[0])).name if command_list else ""
    # The claude runtime authenticates via the OS user's keychain/HOME and
    # cannot run from an isolated HOME; Slack transport tokens stay scrubbed
    # from the child env either way. Follow-up hardening tracked for S7.
    home_override = Path.home() if runtime_kind == "claude" else None
    env = safe_turn_env(
        str(prepared["agent"]),
        int(prepared["turn_id"]),
        str(prepared["session_id"]),
        workspace,
        prepared.get("dispatch_id"),
        home=home_override,
    )
    status = "done"
    exit_code = None
    stdout_text = ""
    stderr_text = ""
    error_text = None
    try:
        completed = subprocess.run(
            prepared["command"],
            input=str(prepared.get("input_text") or ""),
            text=True,
            capture_output=True,
            cwd=workspace,
            env=env,
            timeout=timeout_seconds,
        )
        exit_code = completed.returncode
        stdout_text = completed.stdout or ""
        stderr_text = completed.stderr or ""
        if contains_credential_shape(stdout_text, stderr_text):
            status = "blocked"
            stdout_text = BLOCKED_TURN_OUTPUT
            stderr_text = BLOCKED_TURN_OUTPUT
            error_text = "credential-shaped output blocked"
        elif completed.returncode != 0:
            status = "failed"
            error_text = f"runtime exited with code {completed.returncode}"
    except subprocess.TimeoutExpired:
        status = "timeout"
        error_text = f"runtime timed out after {int(timeout_seconds)}s"
        stdout_text = None
        stderr_text = None
    except OSError as exc:
        status = "failed"
        error_text = f"runtime spawn failed: {type(exc).__name__}"
        stdout_text = None
        stderr_text = None

    if status == "blocked":
        daemon_record_event("turn_credential_blocked", {"id": prepared["turn_id"], "agent": prepared["agent"]})
    elif status == "timeout":
        daemon_record_event("turn_timed_out", {"id": prepared["turn_id"], "agent": prepared["agent"]})

    finalized = finalize_daemon_turn(
        int(prepared["turn_id"]),
        str(prepared["agent"]),
        prepared.get("dispatch_id"),
        str(prepared["owner"]) if prepared.get("owner") is not None else None,
        prepared.get("target"),
        status,
        exit_code,
        clipped_turn_output(stdout_text),
        clipped_turn_output(stderr_text),
        error_text,
    )
    if finalized.get("raw_error"):
        return {"ok": False, "raw_error": str(finalized["raw_error"])}
    if finalized.get("error"):
        return {"ok": False, "error": str(finalized["error"]), "code": str(finalized.get("code", "TURN_FINALIZE_FAILED"))}
    if status != "done":
        return {"ok": False, "error": error_text or "turn failed", "code": "TURN_FAILED"}
    return {
        "ok": True,
        "turn_id": int(prepared["turn_id"]),
        "agent": str(prepared["agent"]),
        "message_id": finalized.get("message_id"),
        "wake_status": finalized.get("wake_status"),
    }


def command_daemon_turn_run(argv: list[str]) -> int:
    unknown = unknown_flags(
        argv,
        {"--agent", "--dispatch-id", "--owner", "--input", "--target", "--session-id", "--timeout"},
    )
    if unknown:
        return write_stderr(f"Error: unknown daemon turn run flag: {unknown[0]}\nCode: INVALID_ARG\n")
    for flag in ("--agent", "--dispatch-id", "--owner", "--input", "--target", "--session-id", "--timeout"):
        if flag_missing_value(argv, flag):
            return write_stderr(f"Error: {flag} requires a value\nCode: INVALID_ARG\n")
    agent = arg_value(argv, "--agent")
    if not agent or not agent.strip():
        return write_stderr("Error: --agent is required\nCode: INVALID_ARG\n")
    dispatch_id = None
    dispatch_id_text = arg_value(argv, "--dispatch-id")
    if dispatch_id_text is not None:
        try:
            dispatch_id = int(dispatch_id_text)
        except ValueError:
            return write_stderr("Error: --dispatch-id must be an integer\nCode: INVALID_ARG\n")
    timeout_seconds, timeout_error = parse_duration_arg(argv, "--timeout", "5m")
    if timeout_error is not None:
        return write_stderr(f"Error: {timeout_error}\nCode: INVALID_ARG\n")
    owner = arg_value(argv, "--owner")
    if dispatch_id is not None and (owner is None or not owner.strip()):
        return write_stderr("Error: --owner is required with --dispatch-id\nCode: INVALID_ARG\n")

    result = execute_daemon_turn(
        agent,
        dispatch_id,
        owner,
        arg_value(argv, "--input"),
        arg_value(argv, "--target"),
        arg_value(argv, "--session-id"),
        timeout_seconds,
    )
    if not result.get("ok"):
        if result.get("raw_error"):
            return write_stderr(str(result["raw_error"]))
        return write_stderr(f"Error: {result['error']}\nCode: {result.get('code', 'TURN_FAILED')}\n")
    message_line = f" message={short_id(str(result['message_id']))}" if result.get("message_id") else ""
    wake_line = f" wake={result['wake_status']}" if result.get("wake_status") else ""
    return write_stdout(f"Turn {result['turn_id']} completed for @{result['agent']}.{message_line}{wake_line}\n")


def command_daemon_turn_list(argv: list[str]) -> int:
    unknown = unknown_flags(argv, {"--agent", "--status"})
    if unknown:
        return write_stderr(f"Error: unknown daemon turn list flag: {unknown[0]}\nCode: INVALID_ARG\n")
    if flag_missing_value(argv, "--agent") or flag_missing_value(argv, "--status"):
        return write_stderr("Error: daemon turn list flags require values\nCode: INVALID_ARG\n")
    agent_filter = arg_value(argv, "--agent")
    if agent_filter is not None:
        agent_filter = agent_filter.removeprefix("@")
    status_filter = arg_value(argv, "--status")
    if status_filter is not None and status_filter not in {"running", "done", "failed", "timeout", "blocked"}:
        return write_stderr("Error: --status must be running, done, failed, timeout, or blocked\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        rows = list(state.get("daemon_turns", []))
        if agent_filter is not None:
            rows = [item for item in rows if item["agent"] == agent_filter]
        if status_filter is not None:
            rows = [item for item in rows if item["status"] == status_filter]
        if not rows:
            return write_stdout("No daemon turns.\n")
        rendered = "\n".join(format_daemon_turn_row(item) for item in rows)
        return write_stdout(f"## Daemon Turns ({len(rows)})\n\n{rendered}\n")

    return with_read_state(action)


def command_daemon_turn(argv: list[str]) -> int:
    if not argv:
        return write_stderr("Error: missing daemon turn subcommand\nCode: INVALID_ARG\n")
    subcommand = argv[0]
    rest = argv[1:]
    if subcommand == "run":
        return command_daemon_turn_run(rest)
    if subcommand == "list":
        return command_daemon_turn_list(rest)
    return write_stderr(f"Error: unknown daemon turn subcommand: {subcommand}\nCode: INVALID_ARG\n")


def command_daemon_dispatch_complete(argv: list[str]) -> int:
    unknown = unknown_flags(argv, {"--id", "--owner"})
    if unknown:
        return write_stderr(f"Error: unknown daemon dispatch complete flag: {unknown[0]}\nCode: INVALID_ARG\n")
    if flag_missing_value(argv, "--id") or flag_missing_value(argv, "--owner"):
        return write_stderr("Error: daemon dispatch complete flags require values\nCode: INVALID_ARG\n")
    id_text = arg_value(argv, "--id")
    owner = arg_value(argv, "--owner")
    if not id_text or not owner or not owner.strip():
        return write_stderr("Error: --id and --owner are required\nCode: INVALID_ARG\n")
    try:
        dispatch_id = int(id_text)
    except ValueError:
        return write_stderr("Error: --id must be an integer\nCode: INVALID_ARG\n")
    owner_name = owner.strip()

    def action(state: dict[str, Any]) -> int:
        item = find_dispatch(state, dispatch_id)
        if item is None:
            return write_stderr(f"Error: Dispatch not found: {dispatch_id}\nCode: NOT_FOUND\n")
        holder_error = dispatch_holder_check(item, owner_name)
        if holder_error is not None:
            return write_stderr(holder_error)
        item["status"] = "done"
        item["completed_time"] = current_timestamp()
        item["lease_owner"] = None
        item["lease_expires_at"] = None
        append_daemon_event(state, "dispatch_completed", {"id": dispatch_id, "owner": owner_name})
        return write_stdout(f"Dispatch {dispatch_id} completed by {owner_name}.\n")

    return with_mutable_state(action)


def command_daemon_dispatch_fail(argv: list[str]) -> int:
    unknown = unknown_flags(argv, {"--id", "--owner", "--error"})
    if unknown:
        return write_stderr(f"Error: unknown daemon dispatch fail flag: {unknown[0]}\nCode: INVALID_ARG\n")
    if (
        flag_missing_value(argv, "--id")
        or flag_missing_value(argv, "--owner")
        or flag_missing_value(argv, "--error")
    ):
        return write_stderr("Error: daemon dispatch fail flags require values\nCode: INVALID_ARG\n")
    id_text = arg_value(argv, "--id")
    owner = arg_value(argv, "--owner")
    error_text = arg_value(argv, "--error") or "unspecified"
    if not id_text or not owner or not owner.strip():
        return write_stderr("Error: --id and --owner are required\nCode: INVALID_ARG\n")
    try:
        dispatch_id = int(id_text)
    except ValueError:
        return write_stderr("Error: --id must be an integer\nCode: INVALID_ARG\n")
    owner_name = owner.strip()

    def action(state: dict[str, Any]) -> int:
        item = find_dispatch(state, dispatch_id)
        if item is None:
            return write_stderr(f"Error: Dispatch not found: {dispatch_id}\nCode: NOT_FOUND\n")
        holder_error = dispatch_holder_check(item, owner_name)
        if holder_error is not None:
            return write_stderr(holder_error)
        item["lease_owner"] = None
        item["lease_expires_at"] = None
        item["error"] = error_text
        if item["attempts"] >= item["max_attempts"]:
            item["status"] = "failed"
            append_daemon_event(state, "dispatch_failed", {"id": dispatch_id, "reason": error_text})
            return write_stdout(f"Dispatch {dispatch_id} failed permanently ({item['attempts']}/{item['max_attempts']} attempts).\n")
        item["status"] = "pending"
        append_daemon_event(state, "dispatch_requeued", {"id": dispatch_id, "reason": error_text})
        return write_stdout(f"Dispatch {dispatch_id} requeued ({item['attempts']}/{item['max_attempts']} attempts used).\n")

    return with_mutable_state(action)


def command_daemon_dispatch_list(argv: list[str]) -> int:
