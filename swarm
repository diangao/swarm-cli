def command_agent_register(argv: list[str]) -> int:
    unknown = unknown_flags(
        argv,
        {"--name", "--display-name", "--runtime", "--workspace", "--avatar-url", "--capability"},
    )
    if unknown:
        return write_stderr(f"Error: unknown agent register flag: {unknown[0]}\nCode: INVALID_ARG\n")
    if (
        flag_missing_value(argv, "--name")
        or flag_missing_value(argv, "--display-name")
        or flag_missing_value(argv, "--runtime")
        or flag_missing_value(argv, "--workspace")
        or flag_missing_value(argv, "--avatar-url")
        or flag_missing_value(argv, "--capability")
    ):
        return write_stderr("Error: Agent register flags require values\nCode: INVALID_ARG\n")
    name = arg_value(argv, "--name")
    display_name = arg_value(argv, "--display-name")
    runtime = arg_value(argv, "--runtime")
    avatar_url = arg_value(argv, "--avatar-url")
    if name is not None:
        name = name.removeprefix("@")
    if not name or not valid_service_name(name):
        return write_stderr("Error: --name must start lowercase and contain only lowercase letters, digits, '_' or '-'\nCode: INVALID_ARG\n")
    if display_name is None or not display_name.strip():
        return write_stderr("Error: --display-name is required\nCode: INVALID_ARG\n")
    if runtime is None or not runtime.strip():
        return write_stderr("Error: --runtime is required\nCode: INVALID_ARG\n")
    workspace_path = arg_value(argv, "--workspace") or f"agents/{name}"
    if not valid_workspace_path(workspace_path):
        return write_stderr("Error: --workspace must be a safe relative path\nCode: INVALID_ARG\n")
    if avatar_url is not None and not avatar_url.strip():
        return write_stderr("Error: --avatar-url must be non-empty\nCode: INVALID_ARG\n")
    capabilities: list[str] = []
    seen: set[str] = set()
    for value in arg_values(argv, "--capability"):
        clean = value.strip()
        if not clean:
            return write_stderr("Error: --capability must be non-empty\nCode: INVALID_ARG\n")
        if clean not in seen:
            capabilities.append(clean)
            seen.add(clean)

    def action(state: dict[str, Any]) -> int:
        existing_profile = profile_by_name(state, name)
        if existing_profile is not None and existing_profile["kind"] != "agent":
            return write_stderr("Error: Agent name conflicts with a human profile\nCode: CONFLICT\n")
        now = current_timestamp()
        existing = agent_by_name(state, name)
        record = agent_item(
            name,
            display_name.strip(),
            runtime.strip(),
            workspace_path,
            capabilities,
            avatar_url.strip() if avatar_url is not None else None,
            existing["created_at"] if existing is not None else now,
            now,
        )
        if existing is None:
            state.setdefault("agents", []).append(record)
        else:
            existing.update(record)
        description = f"Swarm worker runtime={runtime.strip()} workspace={workspace_path}"
        if existing_profile is None:
            state.setdefault("profiles", []).append(
                profile_item(name, display_name.strip(), "agent", description, record.get("avatar_url"))
            )
        else:
            existing_profile["display_name"] = display_name.strip()
            existing_profile["description"] = description
            existing_profile["avatar_url"] = record.get("avatar_url")
            existing_profile["avatar_file"] = None
        return write_stdout(
            f"Agent @{name} registered.\n"
            f"Display name: {display_name.strip()}\n"
            f"Runtime: {runtime.strip()}\n"
            f"Workspace: {workspace_path}\n"
            f"Capabilities: {', '.join(capabilities) if capabilities else '-'}\n"
        )

    return with_mutable_state(action)


