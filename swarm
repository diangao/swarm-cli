    normalized = agent_name.removeprefix("@")
    for record in state.get("daemon_wakes", []):
        if record["agent_name"] == normalized:
            return record
    return None


def mentioned_agent_names(state: dict[str, Any], body: str) -> list[str]:
    names: list[str] = []
    seen: set[str] = set()
    for match in re.finditer(r"@([A-Za-z0-9_-]+)", body):
        candidate = match.group(1)
        normalized = candidate.removeprefix("@")
        if normalized in seen:
            continue
        if agent_by_name(state, normalized) is None:
            continue
        names.append(normalized)
        seen.add(normalized)
    return names


def enqueue_daemon_wake(
    state: dict[str, Any],
    agent_name: str,
    reason: str,
    message_id: str | None,
) -> str:
    agent_name = agent_name.removeprefix("@")
    now = current_timestamp()
    wake = daemon_wake_by_agent(state, agent_name)
    if wake is None:
        wake = daemon_wake_item(
            agent_name,
            False,
            0,
            None,
            None,
            None,
            0,
            None,
            None,
            None,
            now,
        )
        state.setdefault("daemon_wakes", []).append(wake)
    if wake.get("running"):
        wake["pending_count"] = max(1, int(wake.get("pending_count", 0)) + 1)
        if not wake.get("pending_since"):
            wake["pending_since"] = now
        wake["pending_reason"] = reason
        wake["pending_message_id"] = message_id
        wake["updated_at"] = now
        append_daemon_event(
            state,
            "wake_pending",
            {
                "agent": agent_name,
                "reason": reason,
                "message_id": message_id,
                "pending_count": wake["pending_count"],
            },
        )
        return "pending"

    wake["running"] = True
    wake["active_wake_count"] = 1
    wake["active_reason"] = reason
    wake["active_message_id"] = message_id
    wake["active_started_at"] = now
    wake["pending_count"] = 0
    wake["pending_reason"] = None
    wake["pending_message_id"] = None
    wake["pending_since"] = None
    wake["updated_at"] = now
    append_daemon_event(
        state,
        "wake_started",
        {
            "agent": agent_name,
            "reason": reason,
            "message_id": message_id,
            "active_wake_count": wake["active_wake_count"],
        },
    )
    return "started"


def finish_daemon_wake(state: dict[str, Any], agent_name: str) -> tuple[str | None, str | None]:
    agent_name = agent_name.removeprefix("@")
    wake = daemon_wake_by_agent(state, agent_name)
    if wake is None or not wake.get("running"):
        return None, "Agent has no running daemon turn"
    now = current_timestamp()
    if int(wake.get("pending_count", 0)) > 0:
        pending_count = int(wake.get("pending_count", 0))
        wake["running"] = True
        wake["active_wake_count"] = int(wake.get("active_wake_count", 0)) + 1
        wake["active_reason"] = wake.get("pending_reason") or "pending"
        wake["active_message_id"] = wake.get("pending_message_id")
        wake["active_started_at"] = now
        wake["pending_count"] = 0
        wake["pending_reason"] = None
        wake["pending_message_id"] = None
        wake["pending_since"] = None
        wake["updated_at"] = now
        append_daemon_event(
            state,
            "wake_promoted",
            {
                "agent": agent_name,
                "pending_count": pending_count,
                "active_wake_count": wake["active_wake_count"],
                "reason": wake.get("active_reason"),
                "message_id": wake.get("active_message_id"),
            },
        )
        return "promoted", None

    wake["running"] = False
    wake["active_reason"] = None
    wake["active_message_id"] = None
    wake["active_started_at"] = None
    wake["updated_at"] = now
    append_daemon_event(
        state,
        "wake_finished",
        {
            "agent": agent_name,
            "active_wake_count": wake["active_wake_count"],
        },
    )
    return "idle", None


def route_message_wakes(state: dict[str, Any], record: dict[str, Any]) -> list[dict[str, str]]:
    routed: list[dict[str, str]] = []
    mentioned = mentioned_agent_names(state, str(record.get("body", "")))
    for agent_name in mentioned:
        status = enqueue_daemon_wake(state, agent_name, "mention", str(record["id"]))
        routed.append({"agent": agent_name, "status": status, "reason": "mention"})
    if not mentioned and "@" in str(record.get("body", "")):
        append_daemon_event(
            state,
            "wake_route_miss",
            {
                "reason": "mention",
                "message_id": record["id"],
                "target": record["target"],
            },
        )
    # Slock-parity attention: every human channel message wakes every other
    # registered agent; the reply/silence judgment lives in the agent turn
    # (SILENT convention), not in the router.
    author = str(record.get("author") or "")
    if str(record.get("type") or "") == "human" or author.startswith("slack:"):
        for agent in state.get("agents", []):
            agent_name = str(agent["name"])
            if agent_name in mentioned or agent_name == author:
                continue
            status = enqueue_daemon_wake(state, agent_name, "attention", str(record["id"]))
            routed.append({"agent": agent_name, "status": status, "reason": "attention"})
    return routed


def route_reminder_wake(state: dict[str, Any], reminder: dict[str, Any], record: dict[str, Any] | None) -> str | None:
    target = reminder.get("target")
    if not isinstance(target, str) or not target.startswith("dm:@"):
        return None
    agent_name = target.removeprefix("dm:@").split(":", 1)[0].removeprefix("@")
    if agent_by_name(state, agent_name) is None:
        append_daemon_event(
            state,
            "wake_route_miss",
            {
                "reason": "reminder",
                "reminder_id": reminder["id"],
                "target": target,
            },
        )
        return None
    message_id = str(record["id"]) if record is not None else None
    return enqueue_daemon_wake(state, agent_name, "reminder", message_id)


