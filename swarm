def integration_profile_root(service: str) -> Path:
    return state_dir() / "integrations" / service


def ensure_integration_profile_dirs(service: str) -> dict[str, str]:
    root = integration_profile_root(service)
    paths = {
        "HOME": root / "home",
        "XDG_CONFIG_HOME": root / "config",
        "XDG_DATA_HOME": root / "data",
        "XDG_CACHE_HOME": root / "cache",
    }
    for path in paths.values():
        path.mkdir(parents=True, exist_ok=True)
    return {key: str(path) for key, path in paths.items()}


def tasks_for_channel(state: dict[str, Any], channel: str) -> list[dict[str, Any]]:
    return sorted(
        [record for record in state.get("tasks", []) if record["channel"] == channel],
        key=lambda row: int(row["number"]),
    )


def filtered_task_rows(
    rows: list[dict[str, Any]],
    statuses: set[str] | None = None,
    assignee: str | None = None,
    unassigned: bool = False,
) -> list[dict[str, Any]]:
    filtered = rows
    if statuses is not None:
        filtered = [record for record in filtered if record["status"] in statuses]
    if assignee is not None:
        filtered = [record for record in filtered if record.get("assignee") == assignee]
    if unassigned:
        filtered = [record for record in filtered if not record.get("assignee")]
    return filtered


def task_by_number(state: dict[str, Any], channel: str, number: int) -> dict[str, Any] | None:
    for record in tasks_for_channel(state, channel):
        if int(record["number"]) == number:
            return record
    return None


def task_by_message_id(state: dict[str, Any], channel: str, msg_id: str) -> dict[str, Any] | None:
    for record in tasks_for_channel(state, channel):
        full_id = str(record["message_id"])
        if full_id == msg_id or short_id(full_id) == msg_id:
            return record
    return None


def message_by_id_for_channel(state: dict[str, Any], channel: str, msg_id: str) -> dict[str, Any] | None:
    for record in state.get("messages", []):
        full_id = str(record["id"])
        if record["target"] == channel and (full_id == msg_id or short_id(full_id) == msg_id):
            return record
    return None


def channel_has_task_surface(state: dict[str, Any], channel: str) -> bool:
    if channel == "#missing-fixture":
        return False
    if channel in {"#general", "#general:00000000"}:
        return True
    if ":" in channel:
        return False
    return channel.startswith("#") or any(record["channel"] == channel for record in state.get("tasks", []))


def parent_message_for_thread(state: dict[str, Any], target: str) -> dict[str, Any] | None:
    if ":" not in target:
        return None
    channel, root = target.rsplit(":", 1)
    for record in state["messages"]:
        if record["target"] == channel and short_id(record["id"]) == root:
            return record
    return None


def records_for_surface(state: dict[str, Any], target: str) -> list[dict[str, Any]]:
    rows = [record for record in state["messages"] if record["target"] == target]
    if ":" in target:
        parent = parent_message_for_thread(state, target)
        if parent is not None:
            rows = [parent, *rows]
    return sorted(rows, key=lambda row: row["seq"])


def anchor_seq(records: list[dict[str, Any]], anchor: str) -> int | None:
    if anchor.isdigit():
        return int(anchor)
    for record in records:
        msg_id = str(record["id"])
        if msg_id == anchor or short_id(msg_id) == anchor:
            return int(record["seq"])
    return None


def bounded_records(records: list[dict[str, Any]], argv: list[str], limit: int = 20) -> tuple[list[dict[str, Any]], str | None]:
    before = arg_value(argv, "--before")
    after = arg_value(argv, "--after")
    around = arg_value(argv, "--around")
    anchors = [value for value in (before, after, around) if value is not None]
    if len(anchors) > 1:
        return [], "use only one of --before, --after, or --around"
    if before is not None:
        seq = anchor_seq(records, before)
        if seq is None:
            return [], f"anchor not found: {before}"
        return [record for record in records if int(record["seq"]) < seq][-limit:], None
    if after is not None:
        seq = anchor_seq(records, after)
        if seq is None:
            return [], f"anchor not found: {after}"
        return [record for record in records if int(record["seq"]) > seq][:limit], None
    if around is not None:
        seq = anchor_seq(records, around)
        if seq is None:
            return [], f"anchor not found: {around}"
        ordered = sorted(records, key=lambda row: abs(int(row["seq"]) - seq))
        selected = sorted(ordered[: min(limit, len(ordered))], key=lambda row: int(row["seq"]))
        return selected, None
    return records[-limit:], None


def parse_read_limit(argv: list[str]) -> tuple[int, str | None]:
    raw = arg_value(argv, "--limit")
    if raw is None:
        return 20, None
    try:
        value = int(raw)
    except ValueError:
        return 0, "--limit must be a positive integer"
    if value < 1:
        return 0, "--limit must be a positive integer"
    if value > 200:
        return 0, "--limit must be at most 200"
    return value, None


def write_stdout(text: str) -> int:
    sys.stdout.write(text)
    return 0


def write_stderr(text: str, code: int = 1) -> int:
    sys.stderr.write(text)
