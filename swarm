def write_agent_seed_workspace(agent: dict[str, Any], destination: Path) -> None:
    destination.mkdir(parents=True, exist_ok=True)
    for child in ("runtime", "logs", "artifacts"):
        (destination / child).mkdir(exist_ok=True)
    seed = {
        "schema_version": 1,
        "format": "swarm-agent-redacted-seed",
        "status": "format_only_waiting_for_selected_sources",
        "agent": {
            "name": agent["name"],
            "display_name": agent["display_name"],
            "runtime": agent["runtime"],
            "workspace_path": agent["workspace_path"],
            "capabilities": agent.get("capabilities", []),
            "avatar_url": agent.get("avatar_url"),
        },
        "source_policy": {
            "source_material": [],
            "automatic_chat_dump": False,
            "agent_self_runs_export": True,
        },
        "scrub_gates": {
            "internal_demo": ["credentials", "other_people_dm_originals"],
            "possibly_public": ["credentials", "other_people_dm_originals", "pii", "org_or_client_ip"],
        },
        "excluded": [
            "environment files",
            "credential files",
            "raw tokens",
            "other people's direct-message originals",
        ],
    }
    (destination / "seed.json").write_text(json.dumps(seed, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    (destination / "MEMORY.md").write_text(
        f"# {agent['display_name']}\n\n"
        "## Role\n"
        "Long-running Swarm worker. Fill in the role and operating boundaries after source selection.\n\n"
        "## Boundaries\n"
        "- Do not store credentials, tokens, or credential file contents here.\n"
        "- Do not copy other people's direct-message originals into seed artifacts.\n\n"
        "## Active Context\n"
        f"- Seed skeleton generated for @{agent['name']}.\n",
        encoding="utf-8",
    )
    (destination / "README.md").write_text(
        f"# Swarm Agent Workspace: {agent['name']}\n\n"
        "This directory is the persistent workspace skeleton for one long-running Swarm worker.\n"
        "The included seed.json defines the redacted seed format only; real seed content is added after source selection.\n",
        encoding="utf-8",
    )
    (destination / ".gitignore").write_text(
        ".env\n"
        "*.env\n"
        "credential.json\n"
        "credentials/\n"
        "*.token\n"
        "runtime/\n"
        "logs/\n",
        encoding="utf-8",
    )


