def ensure_profile_columns(conn: sqlite3.Connection) -> None:
    columns = {
        row["name"]
        for row in conn.execute("PRAGMA table_info(profiles)").fetchall()
    }
    if "avatar_url" not in columns:
        conn.execute("ALTER TABLE profiles ADD COLUMN avatar_url TEXT")
    if "avatar_file" not in columns:
        conn.execute("ALTER TABLE profiles ADD COLUMN avatar_file TEXT")


def ensure_agent_presence_columns(conn: sqlite3.Connection) -> None:
