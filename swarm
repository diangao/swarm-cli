def valid_env_var_name(value: str) -> bool:
    if not value:
        return False
    first = value[0]
    if not (first == "_" or "A" <= first <= "Z" or "a" <= first <= "z"):
        return False
    return all(char == "_" or "A" <= char <= "Z" or "a" <= char <= "z" or "0" <= char <= "9" for char in value)


