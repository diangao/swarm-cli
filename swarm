def short_id(msg_id: str) -> str:
    return msg_id.split("-", 1)[0]


def format_attachment_summary(record: dict[str, Any]) -> str:
    attachments = record.get("attachments") or []
    if not attachments:
        return ""
    label = "attachment" if len(attachments) == 1 else "attachments"
    items = ", ".join(
        f"{attachment['filename']} (id:{attachment['id']}, {attachment['mime_type']}, "
        f"{attachment['size_bytes']} bytes)"
        for attachment in attachments
    )
    return f" [{len(attachments)} {label}: {items}]"


def format_reaction_summary(record: dict[str, Any]) -> str:
    reactions = record.get("reactions") or []
    if not reactions:
        return ""
    grouped: dict[str, list[str]] = {}
    for reaction in reactions:
        grouped.setdefault(str(reaction["emoji"]), []).append(str(reaction["author"]))
    items = []
    for emoji in sorted(grouped):
        authors = sorted(set(grouped[emoji]))
        items.append(f"{emoji} x{len(authors)} @{', @'.join(authors)}")
    return f" [reactions: {', '.join(items)}]"


def format_history_row(record: dict[str, Any]) -> str:
    return (
        f"[seq={record['seq']} msg={record['id']} time={record['time']} "
        f"type={record['type']}] @{record['author']}: {record['body']}"
        f"{format_attachment_summary(record)}"
        f"{format_reaction_summary(record)}"
    )


def format_canonical_message(record: dict[str, Any]) -> str:
    return (
        f"[target={record['target']} msg={short_id(str(record['id']))} time={record['time']} "
        f"type={record['type']}] @{record['author']}: {record['body']}"
        f"{format_attachment_summary(record)}"
        f"{format_reaction_summary(record)}"
    )


def format_inbox_row(record: dict[str, Any]) -> str:
    msg = record.get("msg") or short_id(str(record["message_id"]))
    return (
        f"[target={record['target']} msg={msg} time={record['time']} "
        f"type={record['type']}] @{record['author']}: {record['body']}"
    )


def format_task_row(record: dict[str, Any]) -> str:
    assignee = f" \u2192 @{record['assignee']}" if record.get("assignee") else ""
    return (
        f"#{record['number']} [{record['status']}] {record['title']}{assignee} "
        f"(by @{record['creator']}) msg={short_id(str(record['message_id']))}"
    )


def format_reminder_row(record: dict[str, Any]) -> str:
    target = f" target={record['target']}" if record.get("target") else ""
    recurrence = f" every={record['recurrence']}" if record.get("recurrence") else ""
    return (
        f"{record['id']} [{record['status']}] {record['title']}{target} "
        f"next={record['next_fire_at']}{recurrence}"
    )


def format_channel_row(record: dict[str, Any]) -> str:
    visibility = "private" if record.get("private") else "public"
    joined = "joined" if record.get("joined") else "not joined"
    description = f" - {record['description']}" if record.get("description") else ""
    return f"- {record['name']} ({visibility}, {joined}){description}"


def format_integration_row(service: dict[str, Any], login: dict[str, Any] | None) -> str:
    if login is None:
        status = "no local record"
        suffix = ""
    else:
        status = f"local record present, account={login['account']}"
        suffix = f" local_home={login['local_home']}"
    env_label = "local env" if service.get("requires_local_env") else "no local env"
    return (
        f"- {service['name']} ({service['kind']}, {status}, {env_label})"
        f" - {service['description']}{suffix}"
    )


def format_agent_row(agent: dict[str, Any], heartbeat: dict[str, Any] | None) -> str:
    capabilities = ",".join(agent.get("capabilities", [])) or "-"
    avatar = f" avatar={agent['avatar_url']}" if agent.get("avatar_url") else ""
    heartbeat_text = " heartbeat=missing"
    if heartbeat is not None:
        heartbeat_text = f" heartbeat={heartbeat['status']} at {heartbeat['updated_at']}"
    presence = agent.get("presence") or "offline"
    presence_text = f" presence={presence}"
    if agent.get("presence_updated_at"):
        presence_text += f" at {agent['presence_updated_at']}"
    if agent.get("last_turn_at"):
        presence_text += f" last_turn={agent['last_turn_at']}"
    return (
        f"- @{agent['name']} ({agent['display_name']}) runtime={agent['runtime']} "
        f"workspace={agent['workspace_path']} capabilities={capabilities}{avatar}{presence_text}{heartbeat_text}"
    )


def member_display(record: dict[str, Any]) -> str:
    parts = [f"@{record['name']}"]
    if record.get("role"):
        parts.append(f"({record['role']})")
    if record.get("status"):
        parts.append(f"({record['status']})")
    return " ".join(parts)


def channel_for_target(target: str) -> str:
    if target.startswith("dm:@"):
        return target
    if ":" in target:
        return target.rsplit(":", 1)[0]
    return target


def source_label(target: str) -> str:
    if target.startswith("dm:@"):
        return target
    if target.startswith("#"):
        body = target[1:]
        if ":" in body:
            return f"thread:{body}"
        return f"channel:{body}"
    return target


def ensure_channel_catalog(state: dict[str, Any], target: str) -> None:
    if not target.startswith("#") or ":" in target:
        return
    if any(channel["name"] == target for channel in state.get("channels", [])):
        return
    state.setdefault("channels", []).append(channel_item(target, False, True, "Local channel"))
    ensure_candidate_member(state, target)


def normalize_slack_id(value: str) -> str:
    normalized = []
    for char in value.lower():
        if char.isalnum():
            normalized.append(char)
        elif char in {"-", "_"}:
            normalized.append("-")
    return "".join(normalized).strip("-")


def slack_channel_target(channel_id: str) -> str | None:
    normalized = normalize_slack_id(channel_id)
    if not normalized:
        return None
    return f"#slack-{normalized}"


def ensure_slack_channel_catalog(
    state: dict[str, Any],
    target: str,
    channel_id: str,
    channel_name: str | None,
) -> None:
    if not target.startswith("#") or ":" in target:
        return
    label = f"Slack channel {channel_id}"
    if channel_name:
        label += f" ({channel_name})"
    record = top_level_channel_record(state, target)
    if record is None:
        state.setdefault("channels", []).append(channel_item(target, False, True, label))
    else:
        record["joined"] = True
        if not record.get("description") or record.get("description") == "Local channel":
            record["description"] = label
    ensure_candidate_member(state, target)


def top_level_channel_record(state: dict[str, Any], channel: str) -> dict[str, Any] | None:
    for record in state.get("channels", []):
        if record["name"] == channel:
            return record
    return None


def ensure_candidate_member(state: dict[str, Any], channel: str) -> None:
    if any(member["channel"] == channel and member["name"] == "candidate" for member in state.get("channel_members", [])):
        return
    state.setdefault("channel_members", []).append(
        channel_member_item(channel, "candidate", "agent", None, "active")
    )


def remove_candidate_member(state: dict[str, Any], channel: str) -> None:
    state["channel_members"] = [
        member
        for member in state.get("channel_members", [])
        if not (member["channel"] == channel and member["name"] == "candidate")
    ]


def target_joined_for_write(state: dict[str, Any], target: str) -> bool:
    if target.startswith("dm:@"):
        return True
    channel = channel_for_target(target)
    record = top_level_channel_record(state, channel)
    return record is None or bool(record.get("joined"))


