def command_slack_ingest(argv: list[str]) -> int:
    payload, payload_error = read_slack_event_payload(argv)
    if payload_error is not None:
        return write_stderr(f"Error: {payload_error}\nCode: INVALID_ARG\n")
    assert payload is not None
    event, event_error = normalized_slack_event(payload)
    if event_error is not None:
        return write_stderr(f"Error: {event_error}\nCode: INVALID_SLACK_EVENT\n")
    assert event is not None

    base_target = slack_channel_target(event["channel_id"])
    if base_target is None:
        return write_stderr("Error: Slack channel id did not map to a swarm channel target\nCode: INVALID_SLACK_EVENT\n")

    def action(state: dict[str, Any]) -> int:
        existing = slack_mapping_by_key(state, event["workspace"], event["channel_id"], event["slack_ts"])
        if existing is not None:
            record = message_by_full_id(state, existing["message_id"])
            if record is None:
                return write_stderr("Error: Slack mapping points to a missing swarm message\nCode: STATE_CORRUPT\n")
            return write_stdout(slack_mapping_output(existing, record, "Slack event already imported."))

        target = base_target
        if event.get("thread_ts"):
            root_mapping = slack_mapping_by_key(state, event["workspace"], event["channel_id"], event["thread_ts"])
            if root_mapping is None:
                return write_stderr(
                    "Error: Slack thread root has not been imported; ingest the root message first\n"
                    "Code: SLACK_THREAD_ROOT_MISSING\n"
                )
            root_record = message_by_full_id(state, root_mapping["message_id"])
            if root_record is None:
                return write_stderr("Error: Slack thread root mapping points to a missing swarm message\nCode: STATE_CORRUPT\n")
            target = f"{channel_for_target(root_mapping['target'])}:{short_id(str(root_record['id']))}"

        ensure_slack_channel_catalog(state, base_target, event["channel_id"], event.get("channel_name"))
        record = append_message(
            state,
            target,
            event["body"],
            sender_type=event["sender_type"],
            author=event["author"],
            timestamp=event["time"],
        )
        mapping = slack_message_item(
            event["workspace"],
            event["channel_id"],
            event.get("channel_name"),
            event["slack_ts"],
            event.get("thread_ts"),
            target,
            record["id"],
            current_timestamp(),
        )
        state.setdefault("slack_messages", []).append(mapping)
        append_inbox_for_message(state, record)
        return write_stdout(slack_mapping_output(mapping, record, "Slack event imported."))

    return with_mutable_state(action)


