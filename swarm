    )


def curator_seed_has_blocked_material(destination: Path) -> str | None:
    checked_names = ["seed.json", "watch-list.json", "MEMORY.md", "runtime/curator-config.json", "runtime/curator_cycle.py"]
    combined = []
    for name in checked_names:
        path = destination / name
        if path.exists():
            combined.append(path.read_text(encoding="utf-8"))
    text = "\n".join(combined)
    if contains_credential_shape(text):
        return "credentials"
    lowered = text.lower()
    if "dm:@" in lowered:
        return "other_people_dm_originals"
    if source_text_is_owner_sensitive(lowered):
        return "owner_sensitive"
    return None


def command_curator_install(argv: list[str]) -> int:
    allowed = {
        "--name",
        "--display-name",
        "--workspace",
        "--source-config",
        "--entity-radar",
        "--owner-watchlist",
        "--report-target",
        "--batch-size",
        "--cadence",
        "--at",
        "--in",
        "--max-runtime",
        "--avatar-url",
        "--grind-server",
        "--grind-db",
        "--prompt-version",
        "--queue-fill-limit",
        "--codex-bin",
        "--codex-model",
        "--codex-home",
    }
    unknown = unknown_flags(argv, allowed)
    if unknown:
        return write_stderr(f"Error: unknown curator install flag: {unknown[0]}\nCode: INVALID_ARG\n")
    for flag in allowed:
        if flag_missing_value(argv, flag):
            return write_stderr(f"Error: {flag} requires a value\nCode: INVALID_ARG\n")
    name = (arg_value(argv, "--name") or "curator").removeprefix("@")
    display_name = arg_value(argv, "--display-name") or "Grind Curator"
    workspace_path = arg_value(argv, "--workspace") or f"agents/{name}"
    report_target = arg_value(argv, "--report-target")
    if not valid_service_name(name):
        return write_stderr("Error: --name must start lowercase and contain only lowercase letters, digits, '_' or '-'\nCode: INVALID_ARG\n")
    if not valid_workspace_path(workspace_path):
        return write_stderr("Error: --workspace must be a safe relative path\nCode: INVALID_ARG\n")
    if report_target is None or not report_target.startswith("#") or ":" in report_target:
        return write_stderr("Error: --report-target must be a top-level channel\nCode: INVALID_ARG\n")
    batch_text = arg_value(argv, "--batch-size") or "10"
    try:
        batch_size = int(batch_text)
    except ValueError:
        batch_size = 0
    if batch_size <= 0 or batch_size > 50:
        return write_stderr("Error: --batch-size must be an integer from 1 to 50\nCode: INVALID_ARG\n")
    cadence = arg_value(argv, "--cadence") or "1h"
    cadence_delta = parse_duration(cadence)
    if cadence_delta is None or cadence_delta.total_seconds() <= 0:
        return write_stderr("Error: --cadence must be a positive duration like 1h\nCode: INVALID_ARG\n")
    max_runtime_seconds, max_runtime_error = parse_duration_arg(argv, "--max-runtime", "5m")
    if max_runtime_error is not None:
        return write_stderr(f"Error: {max_runtime_error}\nCode: INVALID_ARG\n")
    grind_server_text = arg_value(argv, "--grind-server")
    grind_config = None
    if grind_server_text is not None:
        grind_server = Path(grind_server_text).expanduser()
        if not grind_server.exists() or not grind_server.is_dir():
            return write_stderr("Error: --grind-server must point to an existing grind-window server directory\nCode: INVALID_ARG\n")
        if not (grind_server / "package.json").exists():
            return write_stderr("Error: --grind-server must contain package.json\nCode: INVALID_ARG\n")
        grind_db = Path(arg_value(argv, "--grind-db") or str(grind_server / "data" / "grind.db")).expanduser()
        if not grind_db.exists():
            return write_stderr("Error: --grind-db must point to an existing grind.db\nCode: INVALID_ARG\n")
        prompt_version = (arg_value(argv, "--prompt-version") or "curator-v3").strip()
        if not prompt_version or contains_credential_shape(prompt_version):
            return write_stderr("Error: --prompt-version must be non-empty and non-secret\nCode: INVALID_ARG\n")
        queue_fill_limit, queue_fill_error = parse_positive_int_arg(argv, "--queue-fill-limit")
        if queue_fill_error is not None:
            return write_stderr(f"Error: {queue_fill_error}\nCode: INVALID_ARG\n")
        codex_bin = arg_value(argv, "--codex-bin")
        codex_model = arg_value(argv, "--codex-model")
        codex_home = arg_value(argv, "--codex-home")
        for flag, value in (("--codex-bin", codex_bin), ("--codex-model", codex_model), ("--codex-home", codex_home)):
            if value is not None and (not value.strip() or contains_credential_shape(value)):
                return write_stderr(f"Error: {flag} must be non-empty and non-secret\nCode: INVALID_ARG\n")
        grind_config = {
            "grind_server": str(grind_server.resolve()),
            "grind_db_path": str(grind_db.resolve()),
            "prompt_version": prompt_version,
            "queue_fill_limit": queue_fill_limit or max(batch_size, 10),
        }
        if codex_bin is not None:
            grind_config["codex_bin"] = codex_bin.strip()
        if codex_model is not None:
            grind_config["codex_model"] = codex_model.strip()
        if codex_home is not None:
            grind_config["codex_home"] = str(Path(codex_home).expanduser())
    next_fire_at = schedule_time_from_args(argv) or current_timestamp()
    watch_entries, counters, watch_error = load_curator_watch_entries(
        arg_value(argv, "--source-config"),
        arg_value(argv, "--entity-radar"),
        arg_value(argv, "--owner-watchlist"),
    )
    if watch_error is not None:
        return write_stderr(f"Error: {watch_error}\nCode: INVALID_ARG\n")
    avatar_url = arg_value(argv, "--avatar-url")
    if avatar_url is not None and not avatar_url.strip():
        return write_stderr("Error: --avatar-url must be non-empty\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        existing_profile = profile_by_name(state, name)
        if existing_profile is not None and existing_profile["kind"] != "agent":
            return write_stderr("Error: Agent name conflicts with a human profile\nCode: CONFLICT\n")
        ensure_channel_catalog(state, report_target)
        now = current_timestamp()
        runtime = f"{sys.executable} runtime/curator_cycle.py"
        existing = agent_by_name(state, name)
        record = agent_item(
            name,
            display_name.strip(),
            runtime,
            workspace_path,
            ["curator", "watch-list", "queue-writeback"],
            avatar_url.strip() if avatar_url is not None else None,
            existing["created_at"] if existing is not None else now,
            now,
            existing.get("presence", "offline") if existing is not None else "offline",
            existing.get("presence_updated_at") if existing is not None else None,
            existing.get("last_turn_at") if existing is not None else None,
        )
        if existing is None:
            state.setdefault("agents", []).append(record)
        else:
            existing.update(record)
        description = f"Swarm curator runtime workspace={workspace_path}"
        if existing_profile is None:
            state.setdefault("profiles", []).append(profile_item(name, display_name.strip(), "agent", description, record.get("avatar_url")))
        else:
            existing_profile["display_name"] = display_name.strip()
            existing_profile["description"] = description
            existing_profile["avatar_url"] = record.get("avatar_url")
            existing_profile["avatar_file"] = None
        destination = state_dir() / workspace_path
        write_curator_seed_workspace(record, destination, watch_entries, counters, report_target, batch_size, max_runtime_seconds, grind_config)
        blocked = curator_seed_has_blocked_material(destination)
        if blocked is not None:
            return write_stderr(f"Error: curator seed scrub gate failed: {blocked}\nCode: SEED_SCRUB_FAILED\n")
        reminder_title = f"curator scheduled batch @{name}"
        reminder_target = f"dm:@{name}"
        reminder = next(
            (
                item
                for item in state.get("reminders", [])
                if item.get("target") == reminder_target
                and item.get("title") == reminder_title
                and item.get("status") != "canceled"
            ),
            None,
        )
        if reminder is None:
            reminder_id = next_reminder_id(state)
            reminder = reminder_item(
                reminder_id,
                reminder_title,
                reminder_target,
                "scheduled",
                next_fire_at,
                cadence,
                now,
                now,
            )
            state.setdefault("reminders", []).append(reminder)
            reminder_event = "scheduled"
        else:
            reminder_id = str(reminder["id"])
            reminder["status"] = "scheduled"
            reminder["next_fire_at"] = next_fire_at
            reminder["recurrence"] = cadence
            reminder["updated_at"] = now
            reminder_event = "updated"
        append_reminder_event(
            state,
            reminder_id,
            reminder_event,
            f"title={reminder['title']} next={next_fire_at} target={reminder_target} every={cadence}",
        )
        append_daemon_event(
            state,
            "curator_installed",
            {
                "agent": name,
                "workspace": workspace_path,
                "reminder_id": reminder_id,
                "watch_entries": len(watch_entries),
                "batch_size": batch_size,
                "cadence": cadence,
                "report_target": report_target,
            },
        )
        return write_stdout(
            f"Curator @{name} installed.\n"
            f"Workspace: {destination}\n"
            f"Mode: {'grind-db' if grind_config is not None else 'workspace-json'}\n"
            f"Watch entries: {len(watch_entries)}\n"
            "Scrub gate: credentials=0 other_people_dm_originals=0 owner_sensitive=0\n"
            f"Batch size: {batch_size}\n"
            f"Max runtime: {int(max_runtime_seconds)}s\n"
            f"Reminder: {reminder_id} every={cadence} target=dm:@{name} next={next_fire_at}\n"
            f"Report target: {report_target}\n"
        )

    return with_mutable_state(action)


