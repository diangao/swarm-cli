#!/usr/bin/env python3
"""Minimal state-backed candidate Swarm CLI for v0 live conformance."""

from __future__ import annotations

import json
import os
import sys
import tempfile
import uuid
from copy import deepcopy
from pathlib import Path
from typing import Any


SCHEMA_VERSION = 3
STATE_FILE = "state.json"


def message(
    seq: int,
    target: str,
    msg_id: str,
    timestamp: str,
    sender_type: str,
    author: str,
    body: str,
) -> dict[str, Any]:
    return {
        "seq": seq,
        "target": target,
        "id": msg_id,
        "time": timestamp,
        "type": sender_type,
        "author": author,
        "body": body,
    }


def inbox_item(
    target: str,
    msg_id: str,
    timestamp: str,
    sender_type: str,
    author: str,
    body: str,
) -> dict[str, Any]:
    return {
        "target": target,
        "message_id": msg_id,
        "time": timestamp,
        "type": sender_type,
        "author": author,
        "body": body,
    }


