def record_agent_heartbeat(
    state: dict[str, Any],
    name: str,
    status: str,
    pid: str | None,
    session_id: str | None,
    detail: str | None,
) -> str | None:
    if agent_by_name(state, name) is None:
        return "Agent not found"
    now = current_timestamp()
    record = agent_heartbeat_item(
        name,
        status.strip(),
        pid.strip() if pid is not None else None,
        session_id.strip() if session_id is not None else None,
        detail.strip() if detail is not None else None,
        now,
    )
    existing = heartbeat_by_agent(state, name)
    if existing is None:
        state.setdefault("agent_heartbeats", []).append(record)
    else:
        existing.update(record)
    return None


def valid_service_name(name: str) -> bool:
    if not name:
        return False
    allowed = set("abcdefghijklmnopqrstuvwxyz0123456789_-")
    return name[0].islower() and all(char in allowed for char in name)


def valid_workspace_path(value: str) -> bool:
    if not value or value.startswith("/") or "\\" in value:
        return False
    path = Path(value)
    return all(part not in {"", ".", ".."} for part in path.parts)


