def normalize_action_payload(raw_text: str) -> tuple[str, str, dict[str, Any] | None, str | None]:
    if not raw_text.strip():
        return "", "", None, "action JSON is required on stdin"
    try:
        payload = json.loads(raw_text)
    except json.JSONDecodeError:
        return "", "", None, "invalid action JSON"
    if not isinstance(payload, dict):
        return "", "", None, "action JSON must be an object"

    variant = payload.get("type") or payload.get("variant") or payload.get("action")
    if variant not in {"channel:create", "agent:create"}:
        return "", "", None, "action type must be channel:create or agent:create"

    normalized = dict(payload)
    normalized["type"] = variant
    if variant == "channel:create":
        channel_name = normalized.get("name") or normalized.get("channel")
        if not isinstance(channel_name, str) or not channel_name.strip():
            return "", "", None, "channel:create requires name"
        channel_name = channel_name.strip()
        if not channel_name.startswith("#") or ":" in channel_name:
            return "", "", None, "channel:create name must be a top-level #channel"
        normalized["name"] = channel_name
        if "private" in normalized and not isinstance(normalized["private"], bool):
            return "", "", None, "channel:create private must be boolean"
        if "description" in normalized and not isinstance(normalized["description"], str):
            return "", "", None, "channel:create description must be a string"
    if variant == "agent:create":
        agent_name = normalized.get("name") or normalized.get("agent")
        if not isinstance(agent_name, str) or not agent_name.strip():
            return "", "", None, "agent:create requires name"
        agent_name = agent_name.strip().removeprefix("@")
        if any(char.isspace() for char in agent_name):
            return "", "", None, "agent:create name must not contain whitespace"
        normalized["name"] = agent_name
        if "description" in normalized and not isinstance(normalized["description"], str):
            return "", "", None, "agent:create description must be a string"

    payload_json = json.dumps(normalized, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
    return str(variant), payload_json, normalized, None


def action_summary(variant: str, payload: dict[str, Any]) -> str:
    if variant == "channel:create":
        visibility = "private" if payload.get("private") else "public"
        description = payload.get("description")
        suffix = f" - {description}" if isinstance(description, str) and description.strip() else ""
        return f"create {visibility} channel {payload['name']}{suffix}"
    if variant == "agent:create":
        description = payload.get("description")
        suffix = f" - {description}" if isinstance(description, str) and description.strip() else ""
        return f"create agent @{payload['name']}{suffix}"
    return variant


def command_action_prepare(argv: list[str]) -> int:
    target = arg_value(argv, "--target")
    if target is None:
        return write_stderr("Error: --target is required\nCode: INVALID_ARG\n")
    if not (target.startswith("#") or target.startswith("dm:@")):
        return write_stderr("Error: action target must be a channel, thread, or DM\nCode: INVALID_TARGET\n")

    raw_text = sys.stdin.read()
    variant, payload_json, payload, error = normalize_action_payload(raw_text)
    if error is not None or payload is None:
        return write_stderr(f"Error: {error}\nCode: INVALID_ARG\n")

    def action(state: dict[str, Any]) -> int:
        if not target_joined_for_write(state, target):
            return write_stderr(f"Error: Not joined to target: {target}\nCode: NOT_JOINED\n")
        ensure_channel_catalog(state, target)
        action_id = next_action_id(state)
        body = (
            f"Action prepared {action_id} [{variant}]\n"
            f"Summary: {action_summary(variant, payload)}\n"
            "Status: pending human commit"
        )
        record = append_message(state, target, body)
        created_at = current_timestamp()
        state.setdefault("action_cards", []).append(
            action_card_item(
                action_id,
                target,
                variant,
                payload_json,
                "pending",
                "candidate",
                record["id"],
                created_at,
            )
        )
        if target in state.get("freshness", {}):
            state["freshness"][target]["cursor"] = record["seq"]
        return write_stdout(
            f"Action prepared in {target}. Action ID: {action_id}. Message ID: {record['id']}\n"
        )

    return with_mutable_state(action)


