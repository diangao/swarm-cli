def arg_value(argv: list[str], flag: str) -> str | None:
    if flag not in argv:
        return None
    idx = argv.index(flag)
    if idx + 1 >= len(argv):
        return None
    return argv[idx + 1]


def arg_values(argv: list[str], flag: str) -> list[str]:
    values: list[str] = []
    for idx, value in enumerate(argv):
        if value == flag and idx + 1 < len(argv):
            values.append(argv[idx + 1])
    return values


def flag_missing_value(argv: list[str], flag: str) -> bool:
    for idx, value in enumerate(argv):
        if value == flag and (idx + 1 >= len(argv) or argv[idx + 1].startswith("--")):
            return True
    return False


def unknown_flags(argv: list[str], allowed: set[str]) -> list[str]:
    return [value for value in argv if value.startswith("--") and value not in allowed]


